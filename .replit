run = "bash run.sh"
entrypoint = "backend/main.py"
modules = ["python-3.12", "nodejs-20", "bash"]

[nix]
channel = "stable-25_05"

[env]
PYTHONPATH = "/home/runner/${REPL_SLUG}"

[deployment]
run = ["bash", "run.sh"]

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8000
externalPort = 80

[agent]
expertMode = true

[userenv]

[userenv.shared]
ENVIRONMENT = "production"
DEBUG = "false"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m uvicorn backend.main:app --host 0.0.0.0 --port 5000"

[workflows.workflow.metadata]
outputType = "webview"
