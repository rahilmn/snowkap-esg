# =============================================================================
# SNOWKAP ESG Platform — Production Environment (Phase 16)
#
# Copy to .env.production on the deploy host. Every value below is REQUIRED
# in production — the boot-time `_check_production_env()` guard will refuse
# to start the API if any required var is empty or a placeholder.
#
# See docs/PRODUCTION_DEPLOYMENT.md for the full runbook.
# =============================================================================

# --- Environment mode (REQUIRED) -------------------------------------------
# Setting this to `production` activates _check_production_env(), which
# fail-fasts the API at startup if other required vars are missing.
SNOWKAP_ENV=production

# --- Auth (REQUIRED) -------------------------------------------------------
# JWT_SECRET signs all bearer tokens. Must be ≥ 32 chars of real entropy.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Reject unsigned bearer tokens (Phase 11A). Set to 1 in production. The
# 24-hour back-compat window during rollout uses 0; flip to 1 once all
# clients have refreshed.
REQUIRE_SIGNED_JWT=1

# Legacy X-API-Key middleware. Still active for service-to-service callers
# that haven't migrated to JWT yet.
SNOWKAP_API_KEY=

# --- LLM (REQUIRED) --------------------------------------------------------
# OpenAI is the ONLY supported LLM provider (CLAUDE.md "Single LLM provider"
# rule). Pipeline stages 1-2, 10, 12 + perspective generators all use this.
OPENAI_API_KEY=

# --- Email (REQUIRED) ------------------------------------------------------
# Resend handles outbound: Phase 9 share, Phase 10 drip, Phase 11C newsletter.
# The from address must be a verified sender on the Resend dashboard domain.
RESEND_API_KEY=
SNOWKAP_FROM_ADDRESS=Snowkap ESG <newsletter@snowkap.co.in>

# Pre-Phase-10 fallback. Most code paths now read SNOWKAP_FROM_ADDRESS first.
EMAIL_FROM=newsletter@snowkap.co.in

# --- Ingestion (REQUIRED for fresh-news pipeline) -------------------------
# NewsAPI.ai (Event Registry) provides full-text article bodies (2,000-5,000
# chars vs Google News RSS's ~87 chars). Phase 17b made this the primary
# news source. Sign up at https://eventregistry.org/.
NEWSAPI_AI_KEY=

# --- Monitoring (RECOMMENDED) ---------------------------------------------
# Sentry DSN for runtime exceptions. PII-scrubbing is wired in api/main.py
# (recipient emails dropped from event context).
SENTRY_DSN=
SENTRY_ENV=production

# --- CORS (set to your hosted frontend origin) ----------------------------
# Default config in api/main.py allows localhost variants for dev. In
# production add your real domain via the FastAPI CORS middleware config —
# this env var is read by api/main.py if set, otherwise defaults apply.
CORS_ORIGINS=["https://app.snowkap.co.in"]

# --- Optional: legacy SQL paths (NOT used by the current stack) ----------
# The Snowkap engine uses SQLite (data/snowkap.db) and JSON files only.
# These vars are kept blank to suppress accidental imports of the legacy
# postgres / redis paths from a previous codebase. Leave empty.
DATABASE_URL=
REDIS_URL=
