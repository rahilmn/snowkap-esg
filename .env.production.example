# =============================================================================
# SNOWKAP ESG Platform — Production Environment (Phase 16)
#
# Copy to .env.production on the deploy host. Every value below is REQUIRED
# in production — the boot-time `_check_production_env()` guard will refuse
# to start the API if any required var is empty or a placeholder.
#
# See docs/PRODUCTION_DEPLOYMENT.md for the full runbook.
# =============================================================================

# --- Environment mode (REQUIRED) -------------------------------------------
# Setting this to `production` activates _check_production_env(), which
# fail-fasts the API at startup if other required vars are missing.
SNOWKAP_ENV=production

# --- Auth (REQUIRED) -------------------------------------------------------
# JWT_SECRET signs all bearer tokens. Must be ≥ 32 chars of real entropy.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Reject unsigned bearer tokens (Phase 11A). Set to 1 in production. The
# 24-hour back-compat window during rollout uses 0; flip to 1 once all
# clients have refreshed.
REQUIRE_SIGNED_JWT=1

# Legacy X-API-Key middleware. Still active for service-to-service callers
# that haven't migrated to JWT yet.
SNOWKAP_API_KEY=

# --- LLM (REQUIRED) --------------------------------------------------------
# OpenAI is the ONLY supported LLM provider (CLAUDE.md "Single LLM provider"
# rule). Pipeline stages 1-2, 10, 12 + perspective generators all use this.
OPENAI_API_KEY=

# --- Email (REQUIRED) ------------------------------------------------------
# Resend handles outbound: Phase 9 share, Phase 10 drip, Phase 11C newsletter.
# The from address must be a verified sender on the Resend dashboard domain.
RESEND_API_KEY=
SNOWKAP_FROM_ADDRESS=Snowkap ESG <newsletter@snowkap.co.in>

# Pre-Phase-10 fallback. Most code paths now read SNOWKAP_FROM_ADDRESS first.
EMAIL_FROM=newsletter@snowkap.co.in

# --- Ingestion (REQUIRED for fresh-news pipeline) -------------------------
# NewsAPI.ai (Event Registry) provides full-text article bodies (2,000-5,000
# chars vs Google News RSS's ~87 chars). Phase 17b made this the primary
# news source. Sign up at https://eventregistry.org/.
NEWSAPI_AI_KEY=

# --- Monitoring (RECOMMENDED) ---------------------------------------------
# Sentry DSN for runtime exceptions. PII-scrubbing is wired in api/main.py
# (recipient emails dropped from event context).
SENTRY_DSN=
SENTRY_ENV=production

# --- CORS (set to your hosted frontend origin) ----------------------------
# Default config in api/main.py allows localhost variants for dev. In
# production add your real domain via the FastAPI CORS middleware config —
# this env var is read by api/main.py if set, otherwise defaults apply.
CORS_ORIGINS=["https://app.snowkap.co.in"]

# --- Database backend (REQUIRED for Supabase production deploy) ----------
# Switches engine.db.connect() from the default local-SQLite backend to
# Supabase Postgres. Set to `postgres` in production; leave unset (or set
# to `sqlite`) for local dev. The boot-time _check_production_env() guard
# requires SUPABASE_DATABASE_URL to be a real postgresql:// URL when this
# is `postgres` AND SNOWKAP_ENV=production.
SNOWKAP_DB_BACKEND=postgres

# Supabase Postgres connection string. Grab from the Supabase Dashboard:
#   Settings → Database → Connection string → URI
# Use the TRANSACTION POOLER endpoint (port 6543) — the dialect translator
# is tuned for pgbouncer transaction mode.
# URL-encode special chars in the password (e.g. # becomes %23).
SUPABASE_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Pgbouncer transaction-mode statement timeout override. Supabase default is
# 60s which kills long ingest pipelines (40-130s typical). 5 minutes is
# safely above the p95 for a HOME-tier article.
SNOWKAP_PG_STATEMENT_TIMEOUT_MS=300000

# --- Optional: legacy SQL paths (NOT used by the current stack) ----------
# These vars are kept blank to suppress accidental imports of the legacy
# postgres / redis paths from a previous codebase. Leave empty.
DATABASE_URL=
REDIS_URL=

# =============================================================================
# Phase 25 — Automated batch + nightly cycle (W6 / W7 / W10)
# =============================================================================

# --- In-process scheduler (REQUIRED on Replit) ---------------------------
# Default-on in production (auto-detected via SNOWKAP_ENV=production above).
# Set explicitly to "1" if you ever override SNOWKAP_ENV.
SNOWKAP_INPROCESS_SCHEDULER=1

# --- Auto-bootstrap on first API boot (Phase 25 W6) ----------------------
# When set to 1: on the FIRST API start where no Phase 25 tenants exist,
# the API auto-runs scripts/phase25_bootstrap.py in a background thread.
# Idempotent — silent no-op once any customer is onboarded.
# Set to 0 to disable (you'll then run scripts/phase25_bootstrap.py
# manually post-deploy).
SNOWKAP_PHASE25_AUTO_BOOTSTRAP=1

# Path to the HubSpot CSV. Default is the repo-root location:
#     ../hubspot-crm-exports-all-deals-2026-05-01.csv
# Override when the CSV lives elsewhere on the deploy host.
# SNOWKAP_BOOTSTRAP_CSV=/data/customer-deals.csv

# --- Overnight batch cron (Phase 25 W7) ----------------------------------
# Hour (UTC) at which the customer batch runs. Default 1 = 6:30am IST.
# Use 19 if you're on US timezone and want it to land at 2pm local.
SNOWKAP_OVERNIGHT_BATCH_UTC_HOUR=1

# Tunables for the overnight batch (W7 article_selector + parallel workers).
SNOWKAP_OVERNIGHT_FETCH_PER_TENANT=20
SNOWKAP_OVERNIGHT_SELECT_PER_TENANT=3
SNOWKAP_OVERNIGHT_WORKERS=4

# --- Morning digest cron (Phase 25 W10) ----------------------------------
# Default 2:20 UTC = 7:50am IST, 5 minutes after the overnight batch
# typically finishes (gives the audit log time to flush).
SNOWKAP_MORNING_DIGEST_UTC_HOUR=2
SNOWKAP_MORNING_DIGEST_UTC_MINUTE=20

# Recipient inbox for the morning digest.
SNOWKAP_DIGEST_RECIPIENT=sales@snowkap.co.in

# Feature flag: set to 0 to disable the digest entirely (cron job stays
# wired but no-ops; useful during initial rollout if you want the
# overnight batch to run without spamming sales@ before content is good).
SNOWKAP_MORNING_DIGEST_ENABLED=1

# --- Batch onboarding endpoint (Phase 25 W6) -----------------------------
# Set to 0 to disable POST /api/admin/onboard/batch (single-company
# /api/admin/onboard remains available). Useful as a runtime kill-switch
# during incident response.
SNOWKAP_BATCH_ONBOARD_ENABLED=1
