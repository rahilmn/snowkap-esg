# =============================================================================
# SNOWKAP ESG Platform — Production Environment Variables
# Copy to .env.production and fill in real values
# =============================================================================

# --- Application ---
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=  # Generate: python -c "import secrets; print(secrets.token_hex(32))"

# --- Database ---
POSTGRES_PASSWORD=  # Strong random password
DATABASE_URL=postgresql+asyncpg://esg_user:${POSTGRES_PASSWORD}@postgres:5432/esg_platform
DATABASE_URL_SYNC=postgresql://esg_user:${POSTGRES_PASSWORD}@postgres:5432/esg_platform

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Apache Jena ---
JENA_FUSEKI_URL=http://jena-fuseki:3030
JENA_ADMIN_PASSWORD=  # Strong random password

# --- MinIO ---
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=  # Not minioadmin
MINIO_ROOT_PASSWORD=  # Strong random password
MINIO_ACCESS_KEY=${MINIO_ROOT_USER}
MINIO_SECRET_KEY=${MINIO_ROOT_PASSWORD}
MINIO_BUCKET=esg-files

# --- AI / LLM ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- Zep Cloud ---
ZEP_API_KEY=

# --- MiroFish ---
MIROFISH_URL=http://mirofish:5001

# --- Email (Resend) ---
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@snowkap.com

# --- Auth ---
JWT_SECRET=  # Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- CORS ---
CORS_ORIGINS=["https://app.snowkap.com"]

# --- Sentry ---
SENTRY_DSN=

# --- News ---
NEWS_API_KEY=
GNEWS_API_KEY=
