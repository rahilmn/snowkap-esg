# =============================================================================
# SNOWKAP ESG Platform — Environment Variables
# Copy to .env and fill in values
# =============================================================================

# --- Application ---
ENVIRONMENT=development
DEBUG=true
APP_NAME=SNOWKAP ESG Platform
APP_VERSION=2.0.0
SECRET_KEY=change-me-to-a-random-64-char-string-in-production

# --- Database (PostgreSQL 16 + pgvector) ---
DATABASE_URL=postgresql+asyncpg://esg_user:esg_password@localhost:5432/esg_platform
DATABASE_URL_SYNC=postgresql://esg_user:esg_password@localhost:5432/esg_platform
POSTGRES_USER=esg_user
POSTGRES_PASSWORD=esg_password
POSTGRES_DB=esg_platform

# --- Redis 7 ---
REDIS_URL=redis://localhost:6379/0

# --- Apache Jena Fuseki ---
JENA_FUSEKI_URL=http://localhost:3030
JENA_DATASET=esg

# --- MinIO (S3-compatible file storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=esg-files
MINIO_SECURE=false

# --- AI / LLM ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- Zep Cloud (Agent Memory) ---
ZEP_API_KEY=...

# --- MiroFish Prediction Engine ---
MIROFISH_URL=http://localhost:5001

# --- Email (Resend) ---
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@snowkap.com

# --- Auth (JWT + Magic Links) ---
JWT_SECRET=change-me-to-a-random-64-char-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
MAGIC_LINK_EXPIRE_MINUTES=15

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:80"]

# --- Sentry ---
SENTRY_DSN=

# --- News APIs ---
NEWS_API_KEY=
GNEWS_API_KEY=

# --- Legacy (keep for Express migration) ---
SUPABASE_DATABASE_URL=
PERPLEXITY_API_KEY=
LOGO_DEV_API_KEY=
