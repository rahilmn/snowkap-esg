@prefix snw:     <http://snowkap.com/ontology/esg#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# SNOWKAP ESG — Causal Edge Records (Order-2: P→P)
# Source: "00 — Primitives" §7, §8 — complete P→P edge tables
# =============================================================================

# ---- Energy Price (EP) as source ----

snw:edge_EP_OX a snw:CausalEdge ;
    snw:edgeId "P2::EP→OX" ; snw:cause snw:prim_EP ; snw:effect snw:prim_OX ;
    snw:edgeOrder 2 ; snw:directionSign "+" ; snw:functionalForm "linear" ;
    snw:operatorExpression "ΔOpex(t) = β · ΔEP(t−k)" ;
    snw:elasticityOrWeight "0.15–0.35" ; snw:lagK "0–3m" ;
    snw:aggregationRule "additive" ; snw:confidenceLevel "high" ;
    snw:edgeNotes "Energy as % of opex varies 5–35% by sector; use sector-specific β" .

snw:edge_EP_CX a snw:CausalEdge ;
    snw:edgeId "P2::EP→CX" ; snw:cause snw:prim_EP ; snw:effect snw:prim_CX ;
    snw:edgeOrder 2 ; snw:directionSign "mixed" ; snw:functionalForm "threshold" ;
    snw:operatorExpression "ΔCapex(t) = β · ΔEP(t−k) · 𝟙[|ΔEP| > τ]" ;
    snw:elasticityOrWeight "0.05–0.20" ; snw:lagK "1–4q" ;
    snw:aggregationRule "additive" ; snw:confidenceLevel "medium" ;
    snw:edgeNotes "Direction: − short-term (demand destruction suppresses capex); + long-term (energy transition investment). τ = sustained ΔEP ≥ 25% YoY triggers investment regime" .

snw:edge_EP_EU a snw:CausalEdge ;
    snw:edgeId "P2::EP→EU" ; snw:cause snw:prim_EP ; snw:effect snw:prim_EU ;
    snw:edgeOrder 2 ; snw:directionSign "mixed" ; snw:functionalForm "composite" ;
    snw:operatorExpression "ΔEU(t) = β₁·ΔEP(t−k₁) [destruction, 0–1q] + β₂·ΔEP(t−k₂) [investment, 2–6q]" ;
    snw:elasticityOrWeight "0.05–0.15 (destruction) / 0.03–0.10 (investment)" ; snw:lagK "0–6q" ;
    snw:aggregationRule "additive" ; snw:confidenceLevel "medium" ;
    snw:edgeNotes "Switching: sustained ΔEP ≥ 25% YoY triggers investment regime" .

snw:edge_EP_RV a snw:CausalEdge ;
    snw:edgeId "P2::EP→RV" ; snw:cause snw:prim_EP ; snw:effect snw:prim_RV ;
    snw:edgeOrder 2 ; snw:directionSign "−" ; snw:functionalForm "log-linear" ;
    snw:operatorExpression "ΔRevenue(t) = −β · ln(1 + ΔEP(t−k))" ;
    snw:elasticityOrWeight "0.03–0.15" ; snw:lagK "0–2q" ;
    snw:aggregationRule "additive" ; snw:confidenceLevel "medium" ;
    snw:edgeNotes "Demand destruction channel; price-elastic consumer-facing sectors at upper bound" .

snw:edge_EP_FR a snw:CausalEdge ;
    snw:edgeId "P2::EP→FR" ; snw:cause snw:prim_EP ; snw:effect snw:prim_FR ;
    snw:edgeOrder 2 ; snw:directionSign "+" ; snw:functionalForm "linear" ;
    snw:operatorExpression "ΔFreightCost(t) = β · ΔEP(t−k)" ;
    snw:elasticityOrWeight "0.15–0.35" ; snw:lagK "0–1m" ;
    snw:aggregationRule "dominant" ; snw:confidenceLevel "high" ;
    snw:edgeNotes "Fuel/bunker cost = 20–40% of carrier operating cost; pass-through via fuel surcharges" .

snw:edge_EP_DT a snw:CausalEdge ;
    snw:edgeId "P2::EP→DT" ; snw:cause snw:prim_EP ; snw:effect snw:prim_DT ;
    snw:edgeOrder 2 ; snw:directionSign "+" ; snw:functionalForm "threshold" ;
    snw:operatorExpression "ΔDowntime(t) = β · 𝟙[EP > τ_curtailment]" ;
    snw:elasticityOrWeight "0.05–0.20" ; snw:lagK "0–2q" ;
    snw:aggregationRule "additive" ; snw:confidenceLevel "medium" ;
    snw:edgeNotes "Energy curtailment mandates at extreme prices" .

snw:edge_EP_SC a snw:CausalEdge ;
    snw:edgeId "P2::EP→SC" ; snw:cause snw:prim_EP ; snw:effect snw:prim_SC ;
    snw:edgeOrder 2 ; snw:directionSign "+" ; snw:functionalForm "threshold" ;
    snw:operatorExpression "ΔSCRisk(t) = β · 𝟙[ΔEP > τ_supplier_stress]" ;
    snw:elasticityOrWeight "0.05–0.15" ; snw:lagK "0–2q" ;
    snw:aggregationRule "additive" ; snw:confidenceLevel "medium" ;
    snw:edgeNotes "Supplier stress at extreme energy prices" .

# ---- Extreme Weather (XW) as source ----

snw:edge_XW_DT a snw:CausalEdge ;
    snw:edgeId "P2::XW→DT" ; snw:cause snw:prim_XW ; snw:effect snw:prim_DT ;
    snw:edgeOrder 2 ; snw:directionSign "+" ; snw:functionalForm "threshold" ;
    snw:operatorExpression "ΔDowntime(t) = β · HazardIndex(t−k) · 𝟙[HazardIndex > τ]" ;
    snw:elasticityOrWeight "0.20–0.60" ; snw:lagK "0–1m" ;
    snw:aggregationRule "max" ; snw:confidenceLevel "high" ;
    snw:edgeNotes "τ = asset-specific hazard intensity; max aggregation (worst hazard sets downtime)" .

snw:edge_XW_OX a snw:CausalEdge ;
    snw:edgeId "P2::XW→OX" ; snw:cause snw:prim_XW ; snw:effect snw:prim_OX ;
    snw:edgeOrder 2 ; snw:directionSign "+" ; snw:functionalForm "step" ;
    snw:operatorExpression "ΔOpex(t) = β · 𝟙[HazardEvent ≥ τ]" ;
    snw:elasticityOrWeight "0.05–0.20" ; snw:lagK "0–2q" ;
    snw:aggregationRule "additive" ; snw:confidenceLevel "high" ;
    snw:edgeNotes "Disaster response, emergency logistics" .

snw:edge_XW_CX a snw:CausalEdge ;
    snw:edgeId "P2::XW→CX" ; snw:cause snw:prim_XW ; snw:effect snw:prim_CX ;
    snw:edgeOrder 2 ; snw:directionSign "+" ; snw:functionalForm "step" ;
    snw:operatorExpression "ΔCapex(t) = β · 𝟙[HazardDamage ≥ τ]" ;
    snw:elasticityOrWeight "0.10–0.40" ; snw:lagK "0–4q" ;
    snw:aggregationRule "additive" ; snw:confidenceLevel "high" ;
    snw:edgeNotes "Rebuild/hardening capex" .

snw:edge_XW_SC a snw:CausalEdge ;
    snw:edgeId "P2::XW→SC" ; snw:cause snw:prim_XW ; snw:effect snw:prim_SC ;
    snw:edgeOrder 2 ; snw:directionSign "+" ; snw:functionalForm "threshold" ;
    snw:operatorExpression "ΔSCRisk(t) = β · XWIndex(t−k) · 𝟙[XWIndex > τ]" ;
    snw:elasticityOrWeight "0.15–0.40" ; snw:lagK "0–1q" ;
    snw:aggregationRule "additive" ; snw:confidenceLevel "high" ;
    snw:edgeNotes "Infrastructure/logistics disruption from extreme weather" .

snw:edge_XW_WA a snw:CausalEdge ;
    snw:edgeId "P2::XW→WA" ; snw:cause snw:prim_XW ; snw:effect snw:prim_WA ;
    snw:edgeOrder 2 ; snw:directionSign "−" ; snw:functionalForm "threshold" ;
    snw:operatorExpression "ΔWater(t) = −β · DroughtIndex(t−k) · 𝟙[DroughtIndex > τ]" ;
    snw:elasticityOrWeight "0.10–0.40" ; snw:lagK "0–1q" ;
    snw:aggregationRule "additive" ; snw:confidenceLevel "high" ;
    snw:edgeNotes "Drought reduces water availability; τ = PDSI ≤ −3.0 or SPI ≤ −1.5" .

snw:edge_XW_HS a snw:CausalEdge ;
    snw:edgeId "P2::XW→HS" ; snw:cause snw:prim_XW ; snw:effect snw:prim_HS ;
    snw:edgeOrder 2 ; snw:directionSign "+" ; snw:functionalForm "step" ;
    snw:operatorExpression "ΔHSIncidents(t) = β · 𝟙[HazardEvent ≥ τ]" ;
    snw:elasticityOrWeight "0.10–0.30" ; snw:lagK "0–1q" ;
    snw:aggregationRule "additive" ; snw:confidenceLevel "medium" ;
    snw:edgeNotes "Heat stress, flood hazard injuries" .

snw:edge_XW_WF a snw:CausalEdge ;
    snw:edgeId "P2::XW→WF" ; snw:cause snw:prim_XW ; snw:effect snw:prim_WF ;
    snw:edgeOrder 2 ; snw:directionSign "−" ; snw:functionalForm "step" ;
    snw:operatorExpression "ΔWorkforceAvail(t) = −β · 𝟙[DisasterEvent ≥ τ]" ;
    snw:elasticityOrWeight "0.05–0.20" ; snw:lagK "0–1q" ;
    snw:aggregationRule "additive" ; snw:confidenceLevel "medium" ;
    snw:edgeNotes "Mass evacuation/displacement reduces workforce" .

snw:edge_XW_EP a snw:CausalEdge ;
    snw:edgeId "P2::XW→EP" ; snw:cause snw:prim_XW ; snw:effect snw:prim_EP ;
    snw:edgeOrder 2 ; snw:directionSign "+" ; snw:functionalForm "threshold" ;
    snw:operatorExpression "ΔEP(t) = β · XWIndex(t−k) · 𝟙[XWIndex > τ]" ;
    snw:elasticityOrWeight "0.20–0.60" ; snw:lagK "0–1m" ;
    snw:aggregationRule "max" ; snw:confidenceLevel "high" ;
    snw:edgeNotes "Heat spikes power demand; drought cuts hydro supply" .

