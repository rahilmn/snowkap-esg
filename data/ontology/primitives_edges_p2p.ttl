# =============================================================================
# FEEDBACK ARCS (11 closed loops)
# =============================================================================

snw:loop_R1 a snw:FeedbackArc ;
    snw:loopId "R1" ; snw:loopType "reinforcing" ;
    snw:loopPath "EP→OX→GrossMargin→FCF→CreditRating→WACC→CX→EU→GE→RG→EP" ;
    snw:edgeNotes "Master macro feedback; cost squeeze → credit deterioration → underinvestment → emission lock-in → regulatory escalation → energy cost" .

snw:loop_R2 a snw:FeedbackArc ;
    snw:loopId "R2" ; snw:loopType "reinforcing" ;
    snw:loopPath "SC→DT→RV→OX→SC" ;
    snw:edgeNotes "Supply chain failure spiral; stockout → downtime → revenue loss → cost cuts → more supply fragility" .

snw:loop_R3 a snw:FeedbackArc ;
    snw:loopId "R3" ; snw:loopType "reinforcing" ;
    snw:loopPath "CY→DT→RV→CustomerChurn→RV" ;
    snw:edgeNotes "Cyber-disruption churn spiral" .

snw:loop_R4 a snw:FeedbackArc ;
    snw:loopId "R4" ; snw:loopType "reinforcing" ;
    snw:loopPath "SocialLicence→RG→CL→OX" ;
    snw:edgeNotes "Regulatory escalation from community opposition" .

snw:loop_R5 a snw:FeedbackArc ;
    snw:loopId "R5" ; snw:loopType "reinforcing" ;
    snw:loopPath "DT→MaintenanceBacklog→DT" ;
    snw:edgeNotes "Capex/opex trap: deferred maintenance compounds downtime" .

snw:loop_R6 a snw:FeedbackArc ;
    snw:loopId "R6" ; snw:loopType "reinforcing" ;
    snw:loopPath "HS→EmployerBrand→WF→HS" ;
    snw:edgeNotes "Labor spiral: incidents → brand deterioration → talent loss → more incidents" .

snw:loop_B1 a snw:FeedbackArc ;
    snw:loopId "B1" ; snw:loopType "balancing" ;
    snw:loopPath "CarbonCost→OX→EU→GE→CarbonCost" ;
    snw:edgeNotes "Efficiency signal: carbon price incentivizes energy efficiency" .

snw:loop_B2 a snw:FeedbackArc ;
    snw:loopId "B2" ; snw:loopType "balancing" ;
    snw:loopPath "IR→WACC→CX" ;
    snw:edgeNotes "Hurdle rate: rising rates kill marginal projects" .

snw:loop_B3 a snw:FeedbackArc ;
    snw:loopId "B3" ; snw:loopType "balancing" ;
    snw:loopPath "GE→RG→CX→GE" ;
    snw:edgeNotes "Regulation-abatement: emissions trigger regulation → forced capex → emissions fall" .

snw:loop_B4 a snw:FeedbackArc ;
    snw:loopId "B4" ; snw:loopType "balancing" ;
    snw:loopPath "IR→CX→EU→GE→RG→IR" ;
    snw:edgeNotes "Interest→decarbonisation: rate hikes defer efficiency investment → emissions persist" .

snw:loop_B5 a snw:FeedbackArc ;
    snw:loopId "B5" ; snw:loopType "balancing" ;
    snw:loopPath "AssetImpairment→CX→CapacityUtil→RV→FCF→AssetImpairment" ;
    snw:edgeNotes "Asset replacement loop" .
