@prefix snowkap: <http://snowkap.com/ontology/esg#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# SNOWKAP ESG — UN SDG Targets (Phase 4)
#
# 25 material SDG targets with ESG topic triggers + corporate action mapping.
# Used by the ESG Analyst generator so citations are specific ("SDG 8.7 —
# forced labour eradication") not vague ("SDG 8").
# =============================================================================

snowkap:SDGTarget a owl:Class ;
    rdfs:label "SDG Target"@en ;
    rdfs:comment "A specific sub-target within a UN Sustainable Development Goal."@en .

snowkap:sdgGoalNumber a owl:DatatypeProperty ;
    rdfs:domain snowkap:SDGTarget ; rdfs:range xsd:integer .
snowkap:sdgTargetCode a owl:DatatypeProperty ;
    rdfs:domain snowkap:SDGTarget ; rdfs:range xsd:string ;
    rdfs:comment "e.g., '8.7'"@en .
snowkap:sdgTargetTitle a owl:DatatypeProperty ;
    rdfs:domain snowkap:SDGTarget ; rdfs:range xsd:string .
snowkap:sdgTargetDescription a owl:DatatypeProperty ;
    rdfs:domain snowkap:SDGTarget ; rdfs:range xsd:string .
snowkap:sdgTopicTrigger a owl:DatatypeProperty ;
    rdfs:domain snowkap:SDGTarget ; rdfs:range xsd:string ;
    rdfs:comment "comma-separated topic slugs that trigger this SDG mapping"@en .
snowkap:sdgCorporateAction a owl:DatatypeProperty ;
    rdfs:domain snowkap:SDGTarget ; rdfs:range xsd:string .

# -----------------------------------------------------------------------------
# SDG 5 — Gender Equality
# -----------------------------------------------------------------------------

snowkap:sdg_5_5 a snowkap:SDGTarget ;
    snowkap:sdgGoalNumber 5 ;
    snowkap:sdgTargetCode "5.5" ;
    snowkap:sdgTargetTitle "Women's full and effective participation in leadership" ;
    snowkap:sdgTargetDescription "Ensure women's full participation and equal opportunities for leadership at all levels of decision-making" ;
    snowkap:sdgTopicTrigger "women_board, women_workforce, diversity_inclusion, board_governance, executive_succession" ;
    snowkap:sdgCorporateAction "Board composition targets; succession pipeline transparency; pay equity audits" .

# -----------------------------------------------------------------------------
# SDG 6 — Clean Water and Sanitation
# -----------------------------------------------------------------------------

snowkap:sdg_6_3 a snowkap:SDGTarget ;
    snowkap:sdgGoalNumber 6 ;
    snowkap:sdgTargetCode "6.3" ;
    snowkap:sdgTargetTitle "Water quality and pollution reduction" ;
    snowkap:sdgTargetDescription "Improve water quality by reducing pollution, eliminating dumping, halving untreated wastewater" ;
    snowkap:sdgTopicTrigger "water_pollution, hazardous_waste, environmental_violation, effluent_discharge" ;
    snowkap:sdgCorporateAction "Zero liquid discharge (ZLD); effluent treatment capex; CPCB compliance audit" .

snowkap:sdg_6_4 a snowkap:SDGTarget ;
    snowkap:sdgGoalNumber 6 ;
    snowkap:sdgTargetCode "6.4" ;
    snowkap:sdgTargetTitle "Water-use efficiency" ;
    snowkap:sdgTargetDescription "Substantially increase water-use efficiency across all sectors; ensure sustainable withdrawals and address water scarcity" ;
    snowkap:sdgTopicTrigger "water_stress, water_intensity, drought, community_conflict, land_acquisition" ;
    snowkap:sdgCorporateAction "Water-use intensity targets; STP/treated water sourcing; community water partnerships" .

# -----------------------------------------------------------------------------
# SDG 7 — Affordable and Clean Energy
# -----------------------------------------------------------------------------

snowkap:sdg_7_2 a snowkap:SDGTarget ;
    snowkap:sdgGoalNumber 7 ;
    snowkap:sdgTargetCode "7.2" ;
    snowkap:sdgTargetTitle "Substantially increase renewable energy share" ;
    snowkap:sdgTargetDescription "Substantially increase the share of renewable energy in the global energy mix by 2030" ;
    snowkap:sdgTopicTrigger "renewable_energy, transition_announcement, coal_emissions, energy_transition, green_bonds" ;
    snowkap:sdgCorporateAction "RE100 commitment; renewable PPA signings; coal phase-out timeline disclosure" .

snowkap:sdg_7_3 a snowkap:SDGTarget ;
    snowkap:sdgGoalNumber 7 ;
    snowkap:sdgTargetCode "7.3" ;
    snowkap:sdgTargetTitle "Double the rate of improvement in energy efficiency" ;
    snowkap:sdgTargetDescription "Double the global rate of improvement in energy efficiency by 2030" ;
    snowkap:sdgTopicTrigger "energy_intensity, energy_efficiency, industrial_process, transition_announcement" ;
    snowkap:sdgCorporateAction "ISO 50001 certification; process heat recovery; DC modernisation" .

# -----------------------------------------------------------------------------
# SDG 8 — Decent Work and Economic Growth
# -----------------------------------------------------------------------------

snowkap:sdg_8_5 a snowkap:SDGTarget ;
    snowkap:sdgGoalNumber 8 ;
    snowkap:sdgTargetCode "8.5" ;
    snowkap:sdgTargetTitle "Full and productive employment and decent work" ;
    snowkap:sdgTargetDescription "Achieve full and productive employment with equal pay for work of equal value" ;
    snowkap:sdgTopicTrigger "workforce_policy, diversity_inclusion, fair_wages, decent_work" ;
    snowkap:sdgCorporateAction "Pay equity audit; minimum wage + living wage commitments; job-retention disclosure" .

snowkap:sdg_8_7 a snowkap:SDGTarget ;
    snowkap:sdgGoalNumber 8 ;
    snowkap:sdgTargetCode "8.7" ;
    snowkap:sdgTargetTitle "Eradicate forced labour, modern slavery, human trafficking, child labour" ;
    snowkap:sdgTargetDescription "Take immediate and effective measures to eradicate forced labour, end modern slavery and human trafficking, secure the prohibition and elimination of the worst forms of child labour" ;
    snowkap:sdgTopicTrigger "forced_labour, child_labour, modern_slavery, wage_theft, supply_chain_labour, social_violation" ;
    snowkap:sdgCorporateAction "UK Modern Slavery Act statement; supplier audit coverage %; whistleblower system; grievance mechanism" .

snowkap:sdg_8_8 a snowkap:SDGTarget ;
    snowkap:sdgGoalNumber 8 ;
    snowkap:sdgTargetCode "8.8" ;
    snowkap:sdgTargetTitle "Protect labour rights and safe working environments" ;
    snowkap:sdgTargetDescription "Protect labour rights and promote safe and secure working environments for all workers, including migrant workers" ;
    snowkap:sdgTopicTrigger "occupational_health, labour_strike, workforce_policy, factory_audit, workplace_safety" ;
    snowkap:sdgCorporateAction "ISO 45001 certification; LTIFR/fatality disclosure; grievance response time SLA" .

# -----------------------------------------------------------------------------
# SDG 9 — Industry, Innovation and Infrastructure
# -----------------------------------------------------------------------------

snowkap:sdg_9_4 a snowkap:SDGTarget ;
    snowkap:sdgGoalNumber 9 ;
    snowkap:sdgTargetCode "9.4" ;
    snowkap:sdgTargetTitle "Retrofit industries for sustainability" ;
    snowkap:sdgTargetDescription "Upgrade infrastructure and retrofit industries with increased resource-use efficiency and greater adoption of clean technologies" ;
    snowkap:sdgTopicTrigger "capex, transition_announcement, industrial_process, technology_upgrade" ;
    snowkap:sdgCorporateAction "Transition capex ring-fenced (≥30% of total capex by 2030); technology roadmap disclosure" .

# -----------------------------------------------------------------------------
# SDG 11 — Sustainable Cities and Communities
# -----------------------------------------------------------------------------

snowkap:sdg_11_6 a snowkap:SDGTarget ;
    snowkap:sdgGoalNumber 11 ;
    snowkap:sdgTargetCode "11.6" ;
    snowkap:sdgTargetTitle "Reduce environmental impact of cities (air quality, waste)" ;
    snowkap:sdgTargetDescription "Reduce the adverse per-capita environmental impact of cities, including by paying attention to air quality and municipal waste management" ;
    snowkap:sdgTopicTrigger "air_quality, pollution, emissions, community_conflict, urban_operations" ;
    snowkap:sdgCorporateAction "PM2.5/PM10/NOx/SO2 monitoring; emission source inventory; neighbourhood air-quality stations" .

