    snowkap:sdgTargetCode "13.1" ;
    snowkap:sdgTargetTitle "Strengthen resilience to climate-related hazards" ;
    snowkap:sdgTargetDescription "Strengthen resilience and adaptive capacity to climate-related hazards and natural disasters in all countries" ;
    snowkap:sdgTopicTrigger "physical_risk, climate_disaster, extreme_weather, flood, drought, adaptation_capex" ;
    snowkap:sdgCorporateAction "TCFD physical risk assessment; site-level climate vulnerability maps; adaptation capex ring-fence" .

snowkap:sdg_13_2 a snowkap:SDGTarget ;
    snowkap:sdgGoalNumber 13 ;
    snowkap:sdgTargetCode "13.2" ;
    snowkap:sdgTargetTitle "Integrate climate change into national and corporate policy" ;
    snowkap:sdgTargetDescription "Integrate climate change measures into national policies, strategies and planning" ;
    snowkap:sdgTopicTrigger "climate_disclosure, transition_announcement, TCFD, strategy" ;
    snowkap:sdgCorporateAction "SBTi target; internal carbon price; climate-linked executive compensation" .

snowkap:sdg_13_3 a snowkap:SDGTarget ;
    snowkap:sdgGoalNumber 13 ;
    snowkap:sdgTargetCode "13.3" ;
    snowkap:sdgTargetTitle "Education, awareness-raising, capacity on climate" ;
    snowkap:sdgTargetDescription "Improve education, awareness-raising and human and institutional capacity on climate change mitigation and adaptation" ;
    snowkap:sdgTopicTrigger "sustainability_reporting, training, stakeholder_engagement" ;
    snowkap:sdgCorporateAction "Climate awareness training; supplier capacity building; community education programs" .

