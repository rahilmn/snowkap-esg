@prefix snowkap: <http://snowkap.com/ontology/esg#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ─────────────────────────────────────────────────────────────────────────
# Phase 32 — SASB sector materiality TTL
# ─────────────────────────────────────────────────────────────────────────
# Source-of-truth: SASB Standards (as of 2024 ISSB consolidation)
# https://sasb.ifrs.org/standards/
#
# Covers 16 sectors mapped by engine/ingestion/company_onboarder.py
# `_INDUSTRY_TO_SASB`. Each sector carries 3-6 most-material topics
# split into:
#   * snowkap:directMaterial  — topics arising from the company's OWN
#                               operations (Scope 1, workforce, product
#                               safety, governance, etc.)
#   * snowkap:assetBasedMaterial — topics arising from the company's
#                               financed / supplied / portfolio activities
#                               (Scope 3 financed emissions for banks,
#                               supply-chain labour for apparel, etc.)
#
# Weights are 0.4-0.95 on the SASB rubric where:
#   * 0.85-0.95 = "most material" (top 1-2 topics for the sector)
#   * 0.65-0.84 = "highly material"
#   * 0.45-0.64 = "moderately material"
#   * < 0.45    = "low material" (omitted; falls through to ontology default)
#
# Topic URIs reuse the existing knowledge_base.ttl topic namespace
# (topic_climate, topic_supply_chain_labor, topic_water, etc.) so the
# materiality query `STRENDS(STR(?topic), ?topic_id)` matches cleanly.
# ─────────────────────────────────────────────────────────────────────────


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# FINANCIALS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

snowkap:sasb_commercial_banks a snowkap:SASBSector ;
    rdfs:label "Commercial Banks" ;
    snowkap:directMaterial [
        snowkap:topic snowkap:topic_data_privacy ;
        snowkap:materialityWeight "0.90"^^xsd:decimal ;
        snowkap:materialityKind "direct"
    ] ,
    [
        snowkap:topic snowkap:topic_ethics_compliance ;
        snowkap:materialityWeight "0.85"^^xsd:decimal ;
        snowkap:materialityKind "direct"
    ] ,
    [
        snowkap:topic snowkap:topic_stakeholder_governance ;
        snowkap:materialityWeight "0.80"^^xsd:decimal ;
        snowkap:materialityKind "direct"
    ] ,
    [
        snowkap:topic snowkap:topic_human_capital ;
        snowkap:materialityWeight "0.60"^^xsd:decimal ;
        snowkap:materialityKind "direct"
    ] ;
    snowkap:assetBasedMaterial [
        snowkap:topic snowkap:topic_climate ;
        snowkap:materialityWeight "0.95"^^xsd:decimal ;
        snowkap:materialityKind "asset_based"
    ] ,
    [
        snowkap:topic snowkap:topic_emissions ;
        snowkap:materialityWeight "0.90"^^xsd:decimal ;
        snowkap:materialityKind "asset_based"
    ] ,
    [
        snowkap:topic snowkap:topic_supply_chain_labor ;
        snowkap:materialityWeight "0.65"^^xsd:decimal ;
        snowkap:materialityKind "asset_based"
    ] .

