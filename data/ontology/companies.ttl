@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix snowkap: <http://snowkap.com/ontology/esg#> .

snowkap:company_adani_power a snowkap:Company ;
    rdfs:label "Adani Power" ;
    snowkap:belongsToIndustry snowkap:industry_power ;
    snowkap:country "India" ;
    snowkap:hasCapitalization snowkap:tier_large_cap ;
    snowkap:hasFacility snowkap:facility_adani_power_hq_ahmedabad,
        snowkap:facility_adani_power_mundra_plant,
        snowkap:facility_adani_power_tiroda_plant ;
    snowkap:locatedIn snowkap:region_ahmedabad ;
    snowkap:region "Asia-Pacific" ;
    snowkap:sasbCategory "Electric Utilities & Power Generators" ;
    snowkap:slug "adani-power" .

