@prefix snowkap: <http://snowkap.com/ontology/esg#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .

# =============================================================================
# Criticality scoring weights + bands (Phase 51)
#
# Lifted out of engine/analysis/criticality_scorer.py (WEIGHTS_DEFAULT,
# WEIGHTS_BY_ROLE, BAND_THRESHOLDS) per CLAUDE.md Rule #1 — weights/thresholds
# are domain knowledge and belong in the ontology, queried via SPARQL, not
# hardcoded in Python. The scorer keeps the same literals as a logged fallback
# so a missing/edited TTL degrades safely.
#
# One snowkap:CriticalityWeight node per (role, component). Per-role components
# sum to 1.0. Queried by engine.ontology.intelligence.query_criticality_weights.
# =============================================================================

# --- default (no role context) ---
# Phase 51.E — materiality-led, NOT financial-cascade-led. The deck scores every
# article with this default role, and the old 0.30 financial_magnitude weight
# systematically buried genuine ESG-governance events (fraud, regulatory,
# emissions) that have no clean cascade ₹ (financial_magnitude=0) beneath
# financial/business news (results, turnover, fundraises) that does. For an ESG
# product, ESG materiality must dominate; the ₹ cascade is a secondary signal.
snowkap:cw_default_materiality          a snowkap:CriticalityWeight ; snowkap:cwRole "default" ; snowkap:cwComponent "materiality"          ; snowkap:cwValue 0.40  .
snowkap:cw_default_financial_magnitude  a snowkap:CriticalityWeight ; snowkap:cwRole "default" ; snowkap:cwComponent "financial_magnitude"  ; snowkap:cwValue 0.10  .
snowkap:cw_default_actionability        a snowkap:CriticalityWeight ; snowkap:cwRole "default" ; snowkap:cwComponent "actionability"        ; snowkap:cwValue 0.15  .
snowkap:cw_default_painpoint_match      a snowkap:CriticalityWeight ; snowkap:cwRole "default" ; snowkap:cwComponent "painpoint_match"      ; snowkap:cwValue 0.20  .
snowkap:cw_default_recency              a snowkap:CriticalityWeight ; snowkap:cwRole "default" ; snowkap:cwComponent "recency"              ; snowkap:cwValue 0.075 .
snowkap:cw_default_source_authority     a snowkap:CriticalityWeight ; snowkap:cwRole "default" ; snowkap:cwComponent "source_authority"     ; snowkap:cwValue 0.025 .
snowkap:cw_default_sentiment_trajectory a snowkap:CriticalityWeight ; snowkap:cwRole "default" ; snowkap:cwComponent "sentiment_trajectory" ; snowkap:cwValue 0.05  .

# --- cfo (financial magnitude leads) ---
snowkap:cw_cfo_financial_magnitude      a snowkap:CriticalityWeight ; snowkap:cwRole "cfo" ; snowkap:cwComponent "financial_magnitude"  ; snowkap:cwValue 0.40  .
snowkap:cw_cfo_actionability            a snowkap:CriticalityWeight ; snowkap:cwRole "cfo" ; snowkap:cwComponent "actionability"        ; snowkap:cwValue 0.20  .
snowkap:cw_cfo_materiality              a snowkap:CriticalityWeight ; snowkap:cwRole "cfo" ; snowkap:cwComponent "materiality"          ; snowkap:cwValue 0.15  .
snowkap:cw_cfo_painpoint_match          a snowkap:CriticalityWeight ; snowkap:cwRole "cfo" ; snowkap:cwComponent "painpoint_match"      ; snowkap:cwValue 0.10  .
snowkap:cw_cfo_recency                  a snowkap:CriticalityWeight ; snowkap:cwRole "cfo" ; snowkap:cwComponent "recency"              ; snowkap:cwValue 0.075 .
snowkap:cw_cfo_source_authority         a snowkap:CriticalityWeight ; snowkap:cwRole "cfo" ; snowkap:cwComponent "source_authority"     ; snowkap:cwValue 0.025 .
snowkap:cw_cfo_sentiment_trajectory     a snowkap:CriticalityWeight ; snowkap:cwRole "cfo" ; snowkap:cwComponent "sentiment_trajectory" ; snowkap:cwValue 0.05  .

# --- ceo (materiality + painpoint lead) ---
snowkap:cw_ceo_materiality              a snowkap:CriticalityWeight ; snowkap:cwRole "ceo" ; snowkap:cwComponent "materiality"          ; snowkap:cwValue 0.25  .
snowkap:cw_ceo_painpoint_match          a snowkap:CriticalityWeight ; snowkap:cwRole "ceo" ; snowkap:cwComponent "painpoint_match"      ; snowkap:cwValue 0.25  .
snowkap:cw_ceo_financial_magnitude      a snowkap:CriticalityWeight ; snowkap:cwRole "ceo" ; snowkap:cwComponent "financial_magnitude"  ; snowkap:cwValue 0.20  .
snowkap:cw_ceo_actionability            a snowkap:CriticalityWeight ; snowkap:cwRole "ceo" ; snowkap:cwComponent "actionability"        ; snowkap:cwValue 0.10  .
snowkap:cw_ceo_recency                  a snowkap:CriticalityWeight ; snowkap:cwRole "ceo" ; snowkap:cwComponent "recency"              ; snowkap:cwValue 0.125 .
snowkap:cw_ceo_source_authority         a snowkap:CriticalityWeight ; snowkap:cwRole "ceo" ; snowkap:cwComponent "source_authority"     ; snowkap:cwValue 0.025 .
snowkap:cw_ceo_sentiment_trajectory     a snowkap:CriticalityWeight ; snowkap:cwRole "ceo" ; snowkap:cwComponent "sentiment_trajectory" ; snowkap:cwValue 0.05  .

# --- analyst (materiality + painpoint lead, balanced) ---
snowkap:cw_analyst_materiality          a snowkap:CriticalityWeight ; snowkap:cwRole "analyst" ; snowkap:cwComponent "materiality"          ; snowkap:cwValue 0.30  .
snowkap:cw_analyst_painpoint_match      a snowkap:CriticalityWeight ; snowkap:cwRole "analyst" ; snowkap:cwComponent "painpoint_match"      ; snowkap:cwValue 0.25  .
snowkap:cw_analyst_actionability        a snowkap:CriticalityWeight ; snowkap:cwRole "analyst" ; snowkap:cwComponent "actionability"        ; snowkap:cwValue 0.15  .
snowkap:cw_analyst_financial_magnitude  a snowkap:CriticalityWeight ; snowkap:cwRole "analyst" ; snowkap:cwComponent "financial_magnitude"  ; snowkap:cwValue 0.15  .
snowkap:cw_analyst_recency              a snowkap:CriticalityWeight ; snowkap:cwRole "analyst" ; snowkap:cwComponent "recency"              ; snowkap:cwValue 0.075 .
snowkap:cw_analyst_source_authority     a snowkap:CriticalityWeight ; snowkap:cwRole "analyst" ; snowkap:cwComponent "source_authority"     ; snowkap:cwValue 0.025 .
snowkap:cw_analyst_sentiment_trajectory a snowkap:CriticalityWeight ; snowkap:cwRole "analyst" ; snowkap:cwComponent "sentiment_trajectory" ; snowkap:cwValue 0.05  .

# =============================================================================
# Criticality bands — score >= minScore (evaluated high to low).
# Queried by engine.ontology.intelligence.query_criticality_bands.
# =============================================================================
snowkap:cb_critical a snowkap:CriticalityBand ; snowkap:cbLevel "CRITICAL" ; snowkap:cbMinScore 0.75 .
snowkap:cb_high     a snowkap:CriticalityBand ; snowkap:cbLevel "HIGH"     ; snowkap:cbMinScore 0.55 .
snowkap:cb_medium   a snowkap:CriticalityBand ; snowkap:cbLevel "MEDIUM"   ; snowkap:cbMinScore 0.35 .
snowkap:cb_low      a snowkap:CriticalityBand ; snowkap:cbLevel "LOW"      ; snowkap:cbMinScore 0.0  .

# =============================================================================
# Market-commentary comparison markers (Phase 51) — headline phrases that flag
# investor/stock-comparison listicles ("Adani Power vs NTPC — which is a better
# bet? 7 factors investors should watch"). A NON-actionable article whose title
# matches one of these is market commentary: it must not force a compliance
# action or outrank genuine ESG signals in the feed. Queried by
# engine.ontology.intelligence.query_comparison_markers; engine.analysis.
# signal_classifiers keeps an in-code default so a missing TTL degrades safely.
# (Leading/trailing spaces are significant — they enforce word boundaries.)
# =============================================================================
snowkap:cm_vs              a snowkap:ComparisonMarker ; snowkap:cmPhrase " vs "                  .
snowkap:cm_vs_dot          a snowkap:ComparisonMarker ; snowkap:cmPhrase " vs. "                 .
snowkap:cm_versus          a snowkap:ComparisonMarker ; snowkap:cmPhrase " versus "              .
snowkap:cm_better_bet      a snowkap:ComparisonMarker ; snowkap:cmPhrase "better bet"            .
snowkap:cm_better_buy      a snowkap:ComparisonMarker ; snowkap:cmPhrase "better buy"            .
snowkap:cm_which_stock     a snowkap:ComparisonMarker ; snowkap:cmPhrase "which stock"           .
snowkap:cm_which_better    a snowkap:ComparisonMarker ; snowkap:cmPhrase "which is better"       .
snowkap:cm_should_buy      a snowkap:ComparisonMarker ; snowkap:cmPhrase "should you buy"        .
snowkap:cm_buy_or_sell     a snowkap:ComparisonMarker ; snowkap:cmPhrase "buy or sell"           .
snowkap:cm_stocks_watch    a snowkap:ComparisonMarker ; snowkap:cmPhrase "stocks to watch"       .
snowkap:cm_stock_watch     a snowkap:ComparisonMarker ; snowkap:cmPhrase "stock to watch"        .
snowkap:cm_multibagger     a snowkap:ComparisonMarker ; snowkap:cmPhrase "multibagger"           .
snowkap:cm_factors_inv     a snowkap:ComparisonMarker ; snowkap:cmPhrase "factors investors"     .
snowkap:cm_factors_that    a snowkap:ComparisonMarker ; snowkap:cmPhrase "factors that investors" .
snowkap:cm_is_it_a_buy     a snowkap:ComparisonMarker ; snowkap:cmPhrase "is it a buy"           .
