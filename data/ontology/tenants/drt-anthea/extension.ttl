# Pollution / Effluent materiality override
snowkap:tenant_drt-anthea_pollution_weight a snowkap:MaterialityWeight ;
    snowkap:weightForTopic snowkap:topic_pollution ;
    snowkap:weightForIndustry "Chemicals" ;
    snowkap:weightValue 0.95 ;
    snowkap:weightSource "Phase 25 W6 industry-default seeding" ;
    rdfs:comment "Chemicals industry has the highest pollution-incident frequency per revenue; CPCB / EPA enforcement is active." .

