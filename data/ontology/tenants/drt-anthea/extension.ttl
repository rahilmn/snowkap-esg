    snowkap:weightForTopic snowkap:topic_carbon ;
    snowkap:weightForIndustry "Chemicals" ;
    snowkap:weightValue 0.88 ;
    snowkap:weightSource "Phase 25 W6 industry-default seeding" ;
    rdfs:comment "Process emissions (HFCs, N2O) carry 100-1000x CO2 equivalence; regulatory exposure escalating." .

# Chemical Safety materiality override
