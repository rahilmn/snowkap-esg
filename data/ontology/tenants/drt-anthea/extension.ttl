    snowkap:weightForTopic snowkap:topic_water ;
    snowkap:weightForIndustry "Chemicals" ;
    snowkap:weightValue 0.92 ;
    snowkap:weightSource "Phase 25 W6 industry-default seeding" ;
    rdfs:comment "Wastewater treatment is the primary capex line; CSRD ESRS:E3 mandatory disclosure." .

