# =============================================================================
# SECTION 3 — IndicatorEdges (Order-1, IND→P)
# 40 edges spanning all 22 primitives.
# =============================================================================

snw:ie_EnergyPriceIndex_OX a snw:IndicatorEdge ;
    snw:edgeId "IND→OX::EnergyPriceIndex" ; snw:leadsPrimitive snw:prim_OX ;
    snw:edgeOrder 1 ; snw:sourceType "leading_indicator" ;
    snw:directionSign "+" ; snw:functionalForm "linear" ;
    snw:operatorExpression "Opex(t) ≈ Opex(t−1) + α · EnergyIndex(t)" ;
    snw:elasticityOrWeight "0.15–0.35 (5–35% of opex by sector)" ; snw:lagK "0–3m" ;
    snw:aggregationRule "additive" ; snw:confidenceLevel "high" ;
    snw:monotonicity "increasing" ;
    snw:edgeNotes "Energy spend is direct COGS for energy-intensive sectors" .

snw:ie_FreightIndex_OX a snw:IndicatorEdge ;
    snw:edgeId "IND→OX::FreightIndex" ; snw:leadsPrimitive snw:prim_OX ;
    snw:edgeOrder 1 ; snw:sourceType "leading_indicator" ;
    snw:directionSign "+" ; snw:functionalForm "linear" ;
    snw:operatorExpression "Opex(t) ≈ Opex(t−1) + β · FreightIndex(t)" ;
    snw:elasticityOrWeight "0.02–0.08" ; snw:lagK "0–3m" ;
    snw:aggregationRule "additive" ; snw:confidenceLevel "high" ;
    snw:monotonicity "increasing" ;
    snw:edgeNotes "Freight/logistics is direct opex component" .

snw:ie_WageGrowth_OX a snw:IndicatorEdge ;
    snw:edgeId "IND→OX::WageGrowth" ; snw:leadsPrimitive snw:prim_OX ;
    snw:edgeOrder 1 ; snw:sourceType "leading_indicator" ;
    snw:directionSign "+" ; snw:functionalForm "linear" ;
    snw:operatorExpression "Opex(t) ≈ Opex(t−1) + γ · WageGrowth(t)" ;
    snw:elasticityOrWeight "0.10–0.30 (10–30% of opex in services)" ; snw:lagK "0–3m" ;
    snw:aggregationRule "additive" ; snw:confidenceLevel "high" ;
    snw:monotonicity "increasing" ;
    snw:edgeNotes "Labor wage inflation feeds SG&A" .

snw:ie_COGS_SGA_OX a snw:IndicatorEdge ;
    snw:edgeId "IND→OX::COGS_SGA_Actuals" ; snw:lagsPrimitive snw:prim_OX ;
    snw:edgeOrder 1 ; snw:sourceType "lagging_indicator" ;
    snw:directionSign "+" ; snw:functionalForm "linear" ;
    snw:operatorExpression "ReportedOpex(t) = Opex(t−Δ)" ;
