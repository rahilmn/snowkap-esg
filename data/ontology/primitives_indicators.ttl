@prefix snw:     <http://snowkap.com/ontology/esg#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# SNOWKAP ESG — Indicator Instances + IndicatorEdges (Order-1)
# Source: PART 1.txt §4-§6 (rubrics A–AK), §7e (materialized indicator ontology)
#
# Contents:
#   - 37 qualitative rubrics (snw:Indicator, indicatorType "qualitative")
#   - 40 quantitative indicators (snw:Indicator, indicatorType "quantitative")
#   - 40 IndicatorEdge instances (IND→P) spanning all 22 primitives
# =============================================================================

# =============================================================================
# SECTION 1 — Qualitative Rubrics (37, labels A–AK)
# Each rubric is a 0–10 scale qualitative signal.
# Scale levels embedded in rdfs:comment.
# =============================================================================

snw:ind_advisory_severity a snw:Indicator ;
    rdfs:label "Advisory Severity Score (Rubric A)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=no advisories; 2=one minor advisory; 4=multiple advisories with operational impact; 6=clear disruption warnings; 8=severe advisories with sustained impact; 10=active crisis dominating planning"@en .

snw:ind_sentiment_score a snw:Indicator ;
    rdfs:label "Customer/Channel Sentiment Score (Rubric B)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=no signal; 2=anecdotal; 4=consistent mentions; 6=strong directional signal; 8=broad confirmation; 10=demand narrative dominant"@en .

snw:ind_rfp_narrative a snw:Indicator ;
    rdfs:label "RFP Narrative Score (Rubric C)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=no signal; 2=one-off commentary; 4=multiple narratives; 6=clear pattern; 8=strong sustained shift; 10=dominant driver"@en .

snw:ind_disruption_signal a snw:Indicator ;
    rdfs:label "Logistics Disruption Signal (Rubric D)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=none; 2=minor local delays; 4=repeated lane/supplier disruption; 6=material expedite/reroute; 8=widespread; 10=severe dominates logistics outcomes"@en .

snw:ind_policy_signal a snw:Indicator ;
    rdfs:label "Energy Policy Signal (Rubric E)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=none; 2=early rhetoric; 4=credible proposals; 6=pricing response visible; 8=implemented materially moving prices; 10=regime shift dominates price formation"@en .

snw:ind_deferral_signal a snw:Indicator ;
    rdfs:label "Maintenance Deferral Signal (Rubric F)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=no deferral; 2=isolated; 4=multiple with backlog; 6=material backlog stressing risk controls; 8=chronic with elevated downtime risk; 10=severe deferral state"@en .

snw:ind_finding_severity a snw:Indicator ;
    rdfs:label "Cyber Finding Severity (Rubric G)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=no findings; 2=minor low-exploitability; 4=several medium; 6=significant with credible exploit path; 8=multiple critical urgent; 10=active exploitation imminent"@en .

snw:ind_audit_severity a snw:Indicator ;
    rdfs:label "Audit Severity (Rubric H)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=no adverse audit signal; 2=minor nonconformities; 4=repeated; 6=major with leadership escalation; 8=critical outcome; 10=severe audit failure dominates"@en .

snw:ind_report_severity a snw:Indicator ;
    rdfs:label "Compliance Report Severity (Rubric I)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=no reports; 2=low-severity complaints; 4=formal complaints or repeated regulator engagement; 6=notice-like engagement; 8=strong enforcement posture; 10=enforcement action imminent"@en .

snw:ind_employer_brand_score a snw:Indicator ;
    rdfs:label "Employer Brand Score (Rubric J)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=no signal; 2=weak (small review movement); 4=clear deterioration/improvement; 6=strong trend affecting hiring/retention; 8=materially constraining workforce; 10=dominates staffing outcomes"@en .

snw:ind_dispute_signal a snw:Indicator ;
    rdfs:label "Labor Dispute Signal (Rubric K)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=none; 2=low-level tensions; 4=credible dispute risk; 6=active dispute conditions; 8=high disruption probability; 10=severe dispute dominates"@en .

snw:ind_water_restriction_severity a snw:Indicator ;
    rdfs:label "Water Restriction Severity (Rubric L)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=no signal; 2=mild likelihood; 4=credible movement; 6=restrictions likely/partly imposed; 8=strong materially limiting withdrawals; 10=severe dominates water availability"@en .

snw:ind_curtailment_signal a snw:Indicator ;
    rdfs:label "Energy Curtailment Signal (Rubric M)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=none; 2=minor/short event; 4=repeated guidance; 6=material actions in place; 8=sustained materially reducing EU; 10=dominates operational profile"@en .

snw:ind_fuel_switch_signal a snw:Indicator ;
    rdfs:label "Fuel Switch Signal (Rubric N)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=none; 2=early intent/small pilots; 4=clear plans partial execution; 6=execution underway at scale; 8=major switching changing emissions profile; 10=dominates near-term GHG"@en .

snw:ind_efficiency_delta_signal a snw:Indicator ;
    rdfs:label "Efficiency Delta Signal (Rubric O)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=none; 2=small minor events; 4=repeated; 6=material change impacting emissions; 8=large shifts dominating emissions; 10=regime shift dominates"@en .

snw:ind_permit_state a snw:Indicator ;
    rdfs:label "Project Permit State (Rubric P)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=no movement; 2=early-stage; 4=progressing moderate certainty; 6=approvals likely; 8=approved/near-final activation imminent; 10=permits drive capex spend"@en .

snw:ind_supplier_capacity_signal a snw:Indicator ;
    rdfs:label "Supplier Capacity Signal (Rubric Q)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=none; 2=mild manageable; 4=repeated affecting timelines; 6=material pace adjustment; 8=severe limiting capex pace; 10=dominates capex execution"@en .

snw:ind_notice_count a snw:Indicator ;
    rdfs:label "Supplier Notice Count (Rubric R)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=no notices; 2=1 minor; 4=multiple or major; 6=broad-based with mitigation underway; 8=sustained clear cost pressure; 10=dominant driver of cost renegotiation"@en .

snw:ind_approval_state a snw:Indicator ;
    rdfs:label "Capex Approval State (Rubric S)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=projects paused; 2=early-stage discussion; 4=active review material uncertainty; 6=likely approval; 8=greenlit mobilisation underway; 10=approvals pace capex spend"@en .

snw:ind_process_change a snw:Indicator ;
    rdfs:label "Process Change Signal (Rubric T)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=none; 2=minor trials negligible; 4=several with early yield variability; 6=material affecting yield; 8=major program impacting waste; 10=dominates waste dynamics"@en .

snw:ind_alert_severity a snw:Indicator ;
    rdfs:label "Geopolitical Alert Severity (Rubric U)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=none; 2=low-level low-likelihood; 4=credible lane/supplier alerts; 6=material contingency actions; 8=severe high-probability; 10=active disruption dominates supply risk"@en .

snw:ind_community_conflict_signal a snw:Indicator ;
    rdfs:label "Community Conflict Signal (Rubric V)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=none; 2=low-level complaints; 4=repeated; 6=material conflict credible constraints; 8=severe shutdown risk high; 10=dominates water/operational continuity"@en .

snw:ind_supplier_spec_change a snw:Indicator ;
    rdfs:label "Supplier Material Spec Change (Rubric W)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=none; 2=one minor low yield impact; 4=multiple early variability; 6=material affecting waste; 8=severe incompatibilities rework dominates; 10=spec changes dominate waste"@en .

snw:ind_incident_advisory_severity a snw:Indicator ;
    rdfs:label "Incident Advisory Severity (Rubric X)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=none; 2=minor low likelihood; 4=credible mitigation planning; 6=high-likelihood controls stressed; 8=severe downtime probability high; 10=advisories dominate downtime risk"@en .

snw:ind_third_party_risk a snw:Indicator ;
    rdfs:label "Third-Party Risk Assessment (Rubric Y)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=none; 2=low in one vendor; 4=several vendor issues; 6=material remediation/segmentation; 8=severe incident probability higher; 10=third-party risk dominates cyber"@en .

snw:ind_bank_guidance a snw:Indicator ;
    rdfs:label "Bank Guidance Signal (Rubric Z)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=no/neutral; 2=mild tightening; 4=clear tightening terms shift; 6=material availability reduced; 8=severe refinancing difficult; 10=guidance dominates credit availability"@en .

snw:ind_risk_off_sentiment a snw:Indicator ;
    rdfs:label "Risk-Off Sentiment Narrative (Rubric AA)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=none; 2=early tone; 4=broad spreads reacting; 6=sustained financing tightens; 8=severe market shut; 10=risk-off dominates credit outcomes"@en .

snw:ind_policy_uncertainty a snw:Indicator ;
    rdfs:label "Policy Uncertainty Score (Rubric AB)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=none meaningful; 2=mild; 4=credible affecting expectations; 6=high affecting hedging; 8=severe driving FX repricing; 10=uncertainty dominates FX dynamics"@en .

snw:ind_political_risk a snw:Indicator ;
    rdfs:label "Political Risk Score (Rubric AC)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=none; 2=mild isolated; 4=persistent investor behavior changes; 6=high capital controls plausible; 8=severe FX volatility dominates; 10=political risk dominates FX"@en .

snw:ind_regulatory_signal a snw:Indicator ;
    rdfs:label "Regulatory Signal Score (Rubric AD)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=none notable; 2=mild; 4=clear tighter stance; 6=strong signaling with early actions; 8=severe enforcement shift imminent; 10=signaling dominates expectations"@en .

snw:ind_early_warning_severity a snw:Indicator ;
    rdfs:label "Extreme Weather Early Warning (Rubric AE)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=no warning; 2=low-confidence; 4=credible prep begins; 6=high-confidence mitigation underway; 8=severe high expected impact; 10=warning dominates operational planning"@en .

snw:ind_climate_risk_assessment a snw:Indicator ;
    rdfs:label "Climate Risk Assessment Signal (Rubric AF)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=none; 2=minor concerns; 4=material vulnerabilities; 6=significant adaptation underway; 8=severe major capex/insurance impact; 10=climate risk dominates exposure decisions"@en .

snw:ind_sanctions_export_ban a snw:Indicator ;
    rdfs:label "Sanctions / Export Ban Signal (Rubric AG)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=none; 2=early rumors; 4=credible action risk; 6=action likely/partial supply tight; 8=implemented major supply impact; 10=dominant driver of commodity shock"@en .

snw:ind_crop_weather_news a snw:Indicator ;
    rdfs:label "Crop / Weather News Severity (Rubric AH)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=no relevant news; 2=mild adverse; 4=repeated adverse; 6=high-likelihood supply impact; 8=severe prices respond; 10=dominant driver of commodity pricing"@en .

snw:ind_producer_guidance a snw:Indicator ;
    rdfs:label "Producer Guidance Signal (Rubric AI)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=neutral; 2=mild tightening; 4=clear contracts adjust; 6=material allocation risk; 8=severe shortages likely; 10=guidance dominates procurement outcomes"@en .

snw:ind_industrial_relations_temp a snw:Indicator ;
    rdfs:label "Industrial Relations Temperature (Rubric AJ)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=stable; 2=mild tension; 4=persistent negotiation risk; 6=high wage pressure likely; 8=severe disruption likely; 10=dominant driver of labor cost and availability"@en .

snw:ind_retention_risk a snw:Indicator ;
    rdfs:label "Retention Risk Narrative (Rubric AK)"@en ;
    snw:indicatorType "qualitative" ;
    rdfs:comment "0-10 scale. 0=none; 2=mild concern; 4=repeated early churn risk; 6=material comp adjustments; 8=severe workforce stability threatened; 10=dominant driver of labor cost decisions"@en .

