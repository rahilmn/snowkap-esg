@prefix snowkap: <http://snowkap.com/ontology/esg#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# SNOWKAP ESG — Precedent Library (Phase 3)
#
# Named, real-world cases the LLM cites by reference, not by fabrication.
# Each PrecedentCase carries: company name, date, cost, outcome, duration,
# recovery path, and mappings to event types + industries so the ontology
# can surface the 2-3 most relevant cases for any given article.
#
# Sources: SEBI orders, RBI press releases, company annual reports, Reuters
# wire, Mint, Economic Times. See caseSource on each instance.
#
# Coverage (30 cases):
#   - Banking / Financials (6)
#   - Power / Energy (8)
#   - Renewables / Solar (3)
#   - Social / Labour (6)
#   - Climate / Physical (3)
#   - Governance / Fraud (4)
# =============================================================================

# -----------------------------------------------------------------------------
# Schema additions — PrecedentCase class + predicates
# -----------------------------------------------------------------------------

snowkap:PrecedentCase a owl:Class ;
    rdfs:label "Precedent Case"@en ;
    rdfs:comment "A named real-world event with known cost, outcome, and duration. LLM cites these instead of fabricating."@en .

snowkap:caseName a owl:DatatypeProperty ;
    rdfs:domain snowkap:PrecedentCase ; rdfs:range xsd:string .
snowkap:caseCompany a owl:DatatypeProperty ;
    rdfs:domain snowkap:PrecedentCase ; rdfs:range xsd:string .
snowkap:caseDate a owl:DatatypeProperty ;
    rdfs:domain snowkap:PrecedentCase ; rdfs:range xsd:date .
snowkap:caseJurisdiction a owl:DatatypeProperty ;
    rdfs:domain snowkap:PrecedentCase ; rdfs:range xsd:string .
snowkap:caseCostCr a owl:DatatypeProperty ;
    rdfs:domain snowkap:PrecedentCase ; rdfs:range xsd:decimal ;
    rdfs:comment "Known direct financial impact in ₹ Crores"@en .
snowkap:caseDurationMonths a owl:DatatypeProperty ;
    rdfs:domain snowkap:PrecedentCase ; rdfs:range xsd:decimal .
snowkap:caseOutcome a owl:DatatypeProperty ;
    rdfs:domain snowkap:PrecedentCase ; rdfs:range xsd:string .
snowkap:caseRecoveryPath a owl:DatatypeProperty ;
    rdfs:domain snowkap:PrecedentCase ; rdfs:range xsd:string .
snowkap:caseSource a owl:DatatypeProperty ;
    rdfs:domain snowkap:PrecedentCase ; rdfs:range xsd:string .
snowkap:precedesEventType a owl:ObjectProperty ;
    rdfs:domain snowkap:PrecedentCase .
snowkap:precedesIndustry a owl:DatatypeProperty ;
    rdfs:domain snowkap:PrecedentCase ; rdfs:range xsd:string .

# -----------------------------------------------------------------------------
# Banking / Financials (6)
# -----------------------------------------------------------------------------

snowkap:case_pnb_nirav_modi_2018 a snowkap:PrecedentCase ;
    snowkap:caseName "PNB Nirav Modi LoU Fraud" ;
    snowkap:caseCompany "Punjab National Bank" ;
    snowkap:caseDate "2018-02-14"^^xsd:date ;
    snowkap:caseJurisdiction "India" ;
    snowkap:caseCostCr 13500 ;
    snowkap:caseDurationMonths 36 ;
    snowkap:caseOutcome "Stock -50% in 6 months; CEO + multiple officers suspended; ED/CBI investigations; RBI penalties; credit rating downgrade Baa3 → stable watch" ;
    snowkap:caseRecoveryPath "Full internal controls overhaul, SWIFT system ring-fencing, board independence boost. Stock recovered 60% of losses in 24 months after governance reset." ;
    snowkap:caseSource "RBI press release 2018-02; SEBI orders 2019; company annual report FY19" ;
    snowkap:precedesEventType snowkap:event_fraud_disclosure ;
    snowkap:precedesIndustry "Financials/Banking" .

