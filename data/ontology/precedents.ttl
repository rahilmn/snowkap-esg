    snowkap:caseRecoveryPath "SBI + Axis + ICICI capital infusion ₹10,000 Cr; board reconstitution; NPA ratio cut 17% → 9% over 24 months; equity recovered 30% from low but never regained pre-crisis level." ;
    snowkap:caseSource "RBI moratorium order 2020-03-05; SEBI AT1 case July 2023" ;
    snowkap:precedesEventType snowkap:event_regulatory_policy ;
