@prefix snw:     <http://snowkap.com/ontology/esg#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# SNOWKAP ESG — Order-3 (P3) and Order-4 (P4) Causal Chains
# Source: PART 2.md lines 203–3480 (full P3/P4 cascade documentation)
#
# Representation:
#   - Each chain is a snw:CausalEdge with edgeOrder 3 or 4
#   - cause = chain source primitive, effect = chain terminal primitive
#   - chainPath stored in edgeId (e.g., "P3::EP→OX→SC")
#   - operatorExpression holds composed cascade formula
#   - Composed elasticity = product/composition of constituent β ranges
#   - Composed lag = sum of hop lags
# =============================================================================

# =============================================================================
# SECTION 1 — Top 50 High-Confidence P3 Chains
# =============================================================================

snw:chain_P3_EP_FR_SC a snw:CausalEdge ;
    snw:edgeId "P3::EP→FR→SC" ; snw:cause snw:prim_EP ; snw:effect snw:prim_SC ;
    snw:edgeOrder 3 ; snw:directionSign "+" ; snw:functionalForm "composite" ;
    snw:operatorExpression "ΔSC = β₂₃·(β₁₂·ΔEP(t−k₁))(t−k₂)" ;
    snw:elasticityOrWeight "0.04–0.12" ; snw:lagK "0–3m" ;
    snw:aggregationRule "additive" ; snw:confidenceLevel "high" ;
    snw:edgeNotes "Fuel surcharge spike → freight stress → safety-stock cuts. Fastest EP chain. Path: EP→FR→SC" .

snw:chain_P3_XW_DT_RV a snw:CausalEdge ;
    snw:edgeId "P3::XW→DT→RV" ; snw:cause snw:prim_XW ; snw:effect snw:prim_RV ;
