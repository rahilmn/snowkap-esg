    snw:operatorExpression "ΔRV = β₂₃·(β₁₂·XW_hazard)(t−k)" ;
    snw:elasticityOrWeight "0.05–0.18" ; snw:lagK "0–4m" ;
    snw:aggregationRule "additive" ; snw:confidenceLevel "high" ;
    snw:edgeNotes "Asset damage/outage → lost production. Empirically well-documented (hurricane/flood). Path: XW→DT→RV" .

