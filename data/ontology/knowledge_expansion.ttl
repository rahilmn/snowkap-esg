snowkap:gri_205 a snowkap:FrameworkSection ;
    snowkap:belongsToFramework snowkap:GRI ;
    snowkap:sectionCode "GRI:205" ; snowkap:sectionTitle "Anti-corruption" .
snowkap:gri_302 a snowkap:FrameworkSection ;
    snowkap:belongsToFramework snowkap:GRI ;
    snowkap:sectionCode "GRI:302" ; snowkap:sectionTitle "Energy" .
