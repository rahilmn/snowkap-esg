snowkap:event_license_revocation rdfs:comment "Default urgency: immediate. Reversibility: irreversible. Time horizon: days." .
snowkap:event_systemic_regulatory rdfs:comment "Default urgency: high. Reversibility: difficult. Time horizon: months." .
snowkap:event_heavy_penalty rdfs:comment "Default urgency: high. Reversibility: difficult. Time horizon: weeks." .
snowkap:event_esg_rating_change rdfs:comment "Default urgency: medium. Reversibility: moderate. Time horizon: weeks." .
snowkap:event_green_bond rdfs:comment "Default urgency: medium. Reversibility: moderate. Time horizon: months." .
snowkap:event_climate_event rdfs:comment "Default urgency: high. Reversibility: depends on magnitude. Time horizon: immediate." .
snowkap:event_routine_capex rdfs:comment "Default urgency: low. Reversibility: easy. Time horizon: months." .
snowkap:event_award_recognition rdfs:comment "Default urgency: low. Reversibility: easy. Time horizon: months." .

