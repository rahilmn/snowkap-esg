@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix snowkap: <http://snowkap.com/ontology/esg#> .

# =============================================================================
# SNOWKAP ESG — Phase 7 Knowledge Expansion
#
# Additive triples that deepen the ontology:
#   - Framework sections for 8 new frameworks
#   - Financial transmission (Event × CapTier × P&L)
#   - Double materiality (financial vs impact)
#   - SDG targets (key targets per SDG)
#   - ESG metric metadata (unit, method, benchmark)
#   - Stakeholder communication detail
#   - Commodity risk profiles
#   - Time horizon + reversibility rules
#   - Additional materiality weights for target-company industries
#   - Penalty precedents (SEBI / CSRD / SEC / RBI)
#
# NO company-specific risks from MSSSPL / TMW Excel files are copied here.
# =============================================================================

# =============================================================================
# FRAMEWORK SECTIONS
# =============================================================================

# --- Porter 5 Forces (strategy) ---
snowkap:porter_competitive_rivalry a snowkap:FrameworkSection ;
    snowkap:belongsToFramework snowkap:PORTER_5_FORCES ;
    snowkap:sectionCode "P5F:Force1" ;
    snowkap:sectionTitle "Competitive Rivalry" ;
    rdfs:comment "Intensity of direct competition within the industry" .

snowkap:porter_supplier_power a snowkap:FrameworkSection ;
    snowkap:belongsToFramework snowkap:PORTER_5_FORCES ;
    snowkap:sectionCode "P5F:Force2" ;
    snowkap:sectionTitle "Bargaining Power of Suppliers" .

snowkap:porter_buyer_power a snowkap:FrameworkSection ;
    snowkap:belongsToFramework snowkap:PORTER_5_FORCES ;
    snowkap:sectionCode "P5F:Force3" ;
    snowkap:sectionTitle "Bargaining Power of Buyers" .

snowkap:porter_new_entrants a snowkap:FrameworkSection ;
    snowkap:belongsToFramework snowkap:PORTER_5_FORCES ;
    snowkap:sectionCode "P5F:Force4" ;
    snowkap:sectionTitle "Threat of New Entrants" .

snowkap:porter_substitutes a snowkap:FrameworkSection ;
    snowkap:belongsToFramework snowkap:PORTER_5_FORCES ;
    snowkap:sectionCode "P5F:Force5" ;
    snowkap:sectionTitle "Threat of Substitutes" .

snowkap:PORTER_5_FORCES snowkap:hasSection snowkap:porter_competitive_rivalry,
    snowkap:porter_supplier_power, snowkap:porter_buyer_power,
    snowkap:porter_new_entrants, snowkap:porter_substitutes .

# --- McKinsey Three Horizons ---
snowkap:mckinsey_h1 a snowkap:FrameworkSection ;
    snowkap:belongsToFramework snowkap:MCKINSEY_3_HORIZONS ;
    snowkap:sectionCode "M3H:H1" ;
    snowkap:sectionTitle "Horizon 1 — Defend & Extend Core Business" .

snowkap:mckinsey_h2 a snowkap:FrameworkSection ;
    snowkap:belongsToFramework snowkap:MCKINSEY_3_HORIZONS ;
    snowkap:sectionCode "M3H:H2" ;
    snowkap:sectionTitle "Horizon 2 — Build Emerging Businesses" .

snowkap:mckinsey_h3 a snowkap:FrameworkSection ;
    snowkap:belongsToFramework snowkap:MCKINSEY_3_HORIZONS ;
    snowkap:sectionCode "M3H:H3" ;
    snowkap:sectionTitle "Horizon 3 — Create Viable Options for Transformative Growth" .

snowkap:MCKINSEY_3_HORIZONS snowkap:hasSection snowkap:mckinsey_h1,
    snowkap:mckinsey_h2, snowkap:mckinsey_h3 .

