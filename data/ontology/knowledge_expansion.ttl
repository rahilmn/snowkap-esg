    snowkap:belongsToFramework snowkap:GRI ;
    snowkap:sectionCode "GRI:305" ; snowkap:sectionTitle "Emissions" .
snowkap:gri_306 a snowkap:FrameworkSection ;
    snowkap:belongsToFramework snowkap:GRI ;
    snowkap:sectionCode "GRI:306" ; snowkap:sectionTitle "Waste" .
snowkap:gri_401 a snowkap:FrameworkSection ;
    snowkap:belongsToFramework snowkap:GRI ;
    snowkap:sectionCode "GRI:401" ; snowkap:sectionTitle "Employment" .
snowkap:gri_403 a snowkap:FrameworkSection ;
    snowkap:belongsToFramework snowkap:GRI ;
    snowkap:sectionCode "GRI:403" ; snowkap:sectionTitle "Occupational Health & Safety" .
snowkap:gri_405 a snowkap:FrameworkSection ;
    snowkap:belongsToFramework snowkap:GRI ;
    snowkap:sectionCode "GRI:405" ; snowkap:sectionTitle "Diversity and Equal Opportunity" .
snowkap:gri_413 a snowkap:FrameworkSection ;
    snowkap:belongsToFramework snowkap:GRI ;
    snowkap:sectionCode "GRI:413" ; snowkap:sectionTitle "Local Communities" .
snowkap:gri_414 a snowkap:FrameworkSection ;
    snowkap:belongsToFramework snowkap:GRI ;
    snowkap:sectionCode "GRI:414" ; snowkap:sectionTitle "Supplier Social Assessment" .
snowkap:gri_408 a snowkap:FrameworkSection ;
    snowkap:belongsToFramework snowkap:GRI ;
    snowkap:sectionCode "GRI:408" ; snowkap:sectionTitle "Child Labor" ;
    snowkap:profitabilityLink "Child labor discovery → supply chain audit cost ₹5-20 Cr + remediation capex + brand damage → 5-15% B2B revenue at risk from procurement exclusion" .
snowkap:gri_409 a snowkap:FrameworkSection ;
    snowkap:belongsToFramework snowkap:GRI ;
    snowkap:sectionCode "GRI:409" ; snowkap:sectionTitle "Forced or Compulsory Labor" ;
    snowkap:profitabilityLink "Forced labor exposure → import ban risk (US UFLPA, EU CSDDD) + SEBI penalty + institutional investor divestment → 10-25% revenue at risk in export markets" .
snowkap:gri_412 a snowkap:FrameworkSection ;
    snowkap:belongsToFramework snowkap:GRI ;
    snowkap:sectionCode "GRI:412" ; snowkap:sectionTitle "Human Rights Assessment" ;
    snowkap:profitabilityLink "Human rights assessment failure → ESG rating downgrade → passive fund exclusion → FII outflow + cost of capital increase 20-50 bps" .
snowkap:GRI snowkap:hasSection snowkap:gri_205, snowkap:gri_302, snowkap:gri_303,
    snowkap:gri_305, snowkap:gri_306, snowkap:gri_401, snowkap:gri_403,
    snowkap:gri_405, snowkap:gri_408, snowkap:gri_409, snowkap:gri_412, snowkap:gri_413, snowkap:gri_414 .

