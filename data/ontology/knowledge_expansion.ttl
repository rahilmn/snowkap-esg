    snowkap:sortPriority 2 .

# ESG Analyst: compliance-first, then urgency ASC
snowkap:rank_analyst_1 a snowkap:PerspectiveLens ;
    snowkap:forPerspective snowkap:lens_esg_analyst ;
    snowkap:sortKey "type" ;
    snowkap:sortDirection "ASC" ;
    snowkap:sortPriority 1 .

snowkap:rank_analyst_2 a snowkap:PerspectiveLens ;
    snowkap:forPerspective snowkap:lens_esg_analyst ;
    snowkap:sortKey "urgency" ;
    snowkap:sortDirection "ASC" ;
    snowkap:sortPriority 2 .

# ─── Perspective Recommendation Type Preferences ───
# Which recommendation types each perspective should see (and in what emphasis order).
# Types not listed are hidden for that perspective.
snowkap:lens_cfo snowkap:showsRecType "financial", "compliance", "operational" .
snowkap:lens_ceo snowkap:showsRecType "strategic", "esg_positioning", "operational" .
snowkap:lens_esg_analyst snowkap:showsRecType "compliance", "esg_positioning", "strategic", "operational", "financial" .
