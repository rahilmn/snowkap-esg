# =============================================================================
# DOUBLE MATERIALITY (financial vs impact) — CSRD/ESRS requirement
# =============================================================================

snowkap:mat_financial a snowkap:MaterialityType ; rdfs:label "Financial Materiality" ;
    rdfs:comment "Outside-in: ESG issue affects company P&L, cash flow, valuation" .
snowkap:mat_impact a snowkap:MaterialityType ; rdfs:label "Impact Materiality" ;
    rdfs:comment "Inside-out: Company activity impacts environment/society independent of financial effect" .

# --- Banking double materiality ---
snowkap:dm_climate_banking_fin rdf:subject snowkap:topic_climate ; rdf:predicate snowkap:hasFinancialMateriality ;
    rdf:object snowkap:industry_banking ; snowkap:materialityWeight 0.7 .
snowkap:dm_climate_banking_imp rdf:subject snowkap:topic_climate ; rdf:predicate snowkap:hasImpactMateriality ;
    rdf:object snowkap:industry_banking ; snowkap:materialityWeight 0.9 .
snowkap:dm_risk_banking_fin rdf:subject snowkap:topic_risk_management ; rdf:predicate snowkap:hasFinancialMateriality ;
    rdf:object snowkap:industry_banking ; snowkap:materialityWeight 1.0 .
snowkap:dm_dp_banking_fin rdf:subject snowkap:topic_data_privacy ; rdf:predicate snowkap:hasFinancialMateriality ;
    rdf:object snowkap:industry_banking ; snowkap:materialityWeight 1.0 .
snowkap:dm_dp_banking_imp rdf:subject snowkap:topic_data_privacy ; rdf:predicate snowkap:hasImpactMateriality ;
    rdf:object snowkap:industry_banking ; snowkap:materialityWeight 0.8 .
snowkap:dm_ethics_banking_fin rdf:subject snowkap:topic_ethics_compliance ; rdf:predicate snowkap:hasFinancialMateriality ;
    rdf:object snowkap:industry_banking ; snowkap:materialityWeight 1.0 .
snowkap:dm_ethics_banking_imp rdf:subject snowkap:topic_ethics_compliance ; rdf:predicate snowkap:hasImpactMateriality ;
    rdf:object snowkap:industry_banking ; snowkap:materialityWeight 0.9 .

