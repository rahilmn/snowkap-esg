# =============================================================================
# ESG METRIC METADATA
# =============================================================================

snowkap:metric_scope1 a snowkap:ESGMetric ; rdfs:label "Scope 1 GHG Emissions" ;
    snowkap:unit "tCO2e" ;
    snowkap:calculationMethod "Direct emissions from owned/controlled sources" ;
    rdfs:comment "Benchmark: industry median from CDP Climate Disclosures" .

snowkap:metric_scope2 a snowkap:ESGMetric ; rdfs:label "Scope 2 GHG Emissions" ;
    snowkap:unit "tCO2e" ;
    snowkap:calculationMethod "Indirect emissions from purchased electricity/heat/steam" .

snowkap:metric_scope3 a snowkap:ESGMetric ; rdfs:label "Scope 3 GHG Emissions" ;
    snowkap:unit "tCO2e" ;
    snowkap:calculationMethod "Indirect emissions in value chain (15 categories)" .

snowkap:metric_energy_intensity a snowkap:ESGMetric ; rdfs:label "Energy Intensity" ;
    snowkap:unit "MWh per ₹ Cr revenue" ;
    snowkap:calculationMethod "Total energy consumed / revenue in ₹ Cr" .

snowkap:metric_water_withdrawal a snowkap:ESGMetric ; rdfs:label "Water Withdrawal" ;
    snowkap:unit "megalitres" ;
    snowkap:calculationMethod "Total water withdrawn from surface, ground, sea, municipal sources" .

snowkap:metric_water_recycling a snowkap:ESGMetric ; rdfs:label "Water Recycling Rate" ;
    snowkap:unit "%" ;
    snowkap:calculationMethod "(Water recycled / water withdrawn) × 100" .

snowkap:metric_ltifr a snowkap:ESGMetric ; rdfs:label "Lost Time Injury Frequency Rate (LTIFR)" ;
    snowkap:unit "injuries per million hours worked" ;
    snowkap:calculationMethod "(Lost-time injuries × 1,000,000) / total hours worked" .

snowkap:metric_fatality_rate a snowkap:ESGMetric ; rdfs:label "Fatality Rate" ;
    snowkap:unit "fatalities per 100,000 employees" .

snowkap:metric_attrition a snowkap:ESGMetric ; rdfs:label "Employee Attrition" ;
    snowkap:unit "%" ;
    snowkap:calculationMethod "(Employees leaving / average headcount) × 100 (annualised)" .

snowkap:metric_gender_pay_gap a snowkap:ESGMetric ; rdfs:label "Gender Pay Gap" ;
    snowkap:unit "%" ;
    snowkap:calculationMethod "(Male median pay − female median pay) / male median pay × 100" .

snowkap:metric_women_in_leadership a snowkap:ESGMetric ; rdfs:label "Women in Leadership" ;
    snowkap:unit "%" ;
    snowkap:calculationMethod "Female headcount in senior mgmt / total senior mgmt × 100" .

snowkap:metric_board_independence a snowkap:ESGMetric ; rdfs:label "Board Independence" ;
    snowkap:unit "%" ;
    snowkap:calculationMethod "Independent directors / total board size × 100" .

snowkap:metric_ceo_pay_ratio a snowkap:ESGMetric ; rdfs:label "CEO Pay Ratio" ;
    snowkap:unit "×" ;
    snowkap:calculationMethod "CEO total compensation / median employee compensation" .

snowkap:metric_data_breaches a snowkap:ESGMetric ; rdfs:label "Material Data Breaches" ;
    snowkap:unit "count" ;
    snowkap:calculationMethod "Count of incidents triggering DPDP / GDPR notification" .

snowkap:metric_green_revenue a snowkap:ESGMetric ; rdfs:label "Green Revenue" ;
    snowkap:unit "₹ Cr" ;
    snowkap:calculationMethod "Revenue from EU Taxonomy-aligned activities" .

snowkap:metric_renewable_share a snowkap:ESGMetric ; rdfs:label "Renewable Energy Share" ;
    snowkap:unit "%" ;
    snowkap:calculationMethod "Renewable MWh / total MWh × 100" .

# =============================================================================
# STAKEHOLDER IMPACT MODEL (enriched with concern descriptions, severity, transmission)
# =============================================================================

snowkap:stakeholder_investors rdfs:comment "Communication channels: annual report, investor day, ESG ratings, quarterly results, roadshows" ;
    snowkap:careAbout snowkap:topic_risk_management, snowkap:topic_tax_transparency, snowkap:topic_ethics_compliance, snowkap:topic_transparency, snowkap:topic_board_leadership, snowkap:topic_supply_chain_labor ;
    snowkap:investorConcern "FII/DII sentiment shift, analyst downgrade risk, ESG fund exclusion, passive index rebalancing, bond spread widening, institutional holder engagement escalation. For social/labor violations: MSCI ESG downgrade, B2B procurement exclusion, US UFLPA import ban risk, EU CSDDD due diligence failure" ;
    snowkap:investorTransmission "Penalty/fine event → contingent liability → earnings revision → analyst downgrade → FII outflow → share price impact (lag 1-4 weeks). ESG rating downgrade → passive fund exclusion → forced selling (lag 1-3 months). Child/forced labor discovery → immediate MSCI review → ESG fund divestment (lag 1-2 weeks)." ;
    snowkap:investorSeverityTrigger "Fine ≥ 0.1% of market cap = MODERATE concern. Fine ≥ 0.5% of market cap = HIGH concern. Recurring penalties or systemic governance failure = CRITICAL concern triggering board engagement. ANY child labor or forced labor finding = CRITICAL regardless of financial quantum." .

snowkap:stakeholder_employees rdfs:comment "Communication channels: town halls, engagement surveys, internal newsletter, grievance mechanism" ;
    snowkap:careAbout snowkap:topic_ethics_compliance, snowkap:topic_health_safety, snowkap:topic_dei, snowkap:topic_human_capital, snowkap:topic_supply_chain_labor ;
    snowkap:employeeConcern "Talent retention risk, employer brand erosion, whistleblower culture impact, union response. For supply chain labor violations: employee morale shock, internal ethics culture questioned, senior talent attrition accelerated" ;
    snowkap:employeeTransmission "Public penalty → employer brand damage → attrition of senior talent (lag 2-6 months). Safety incident → union escalation → productivity loss (lag 0-1 month). Child labor discovery → employer brand crisis → 10-20% increase in attrition intent (lag 1-3 months)." .

snowkap:stakeholder_community rdfs:comment "Communication channels: public meetings, grievance redressal, CSR reports, village panchayat dialogues" ;
    snowkap:careAbout snowkap:topic_biodiversity, snowkap:topic_health_safety, snowkap:topic_community, snowkap:topic_water, snowkap:topic_pollution, snowkap:topic_supply_chain_labor ;
    snowkap:communityConcern "Social licence to operate risk, protest/blockade risk, NGO campaign targeting, local government intervention. For labor violations: community outrage, NGO naming campaigns (Amnesty, HRW), political intervention, permit review" ;
    snowkap:communityTransmission "Environmental violation → community health concern → protest → regulatory investigation → permit risk (lag 1-6 months). Labor violation → NGO campaign → media coverage → political pressure → regulatory crackdown (lag 1-4 months)." .

snowkap:stakeholder_regulators rdfs:comment "Communication channels: disclosure filings, compliance reports, official consultations" ;
    snowkap:careAbout snowkap:topic_climate, snowkap:topic_risk_management, snowkap:topic_tax_transparency, snowkap:topic_ethics_compliance, snowkap:topic_transparency, snowkap:topic_emissions ;
    snowkap:regulatorConcern "Enforcement escalation, show-cause notices, licence review, mandatory audit requirement, sector-wide rule tightening" ;
    snowkap:regulatorTransmission "Compliance failure → SEBI/RBI inquiry → show-cause notice → penalty or trading restriction (lag 2-8 quarters). Systemic failure → sector-wide regulatory tightening." .

snowkap:stakeholder_customers rdfs:comment "Communication channels: product labelling, customer portals, sustainability marketing" ;
    snowkap:careAbout snowkap:topic_ethics_compliance, snowkap:topic_product_safety, snowkap:topic_data_privacy ;
    snowkap:customerConcern "Brand trust erosion, B2B procurement ESG criteria exclusion, customer churn for retail-facing companies" ;
    snowkap:customerTransmission "Public ESG incident → media coverage → B2B customers review supplier ESG score → potential exclusion from procurement shortlist (lag 1-4 quarters)." .

# =============================================================================
# COMMODITY RISK PROFILES
# =============================================================================

snowkap:commodity_coal rdfs:comment "Price volatility: high. Climate exposure: transition risk (phase-out). CBAM: applicable for EU-bound coal-intensive exports." .
snowkap:commodity_natural_gas rdfs:comment "Price volatility: very high (Ukraine war effects). Climate exposure: transition risk (methane). CBAM: partial." .
snowkap:commodity_solar_panels rdfs:comment "Supply concentration: China >80% polysilicon. Geopolitical risk: high. Labour risk: Xinjiang concerns." .
snowkap:commodity_wind_turbines rdfs:comment "Supply concentration: China + EU. Rare earth dependency: medium. CBAM: partial." .
snowkap:commodity_steel rdfs:comment "Price volatility: high. Climate exposure: Scope 1 intensive. CBAM: applicable." .
snowkap:commodity_water rdfs:comment "Stress zones: 20% Indian districts. Not traded but scarcity risk high for power/mining/chemicals." .
snowkap:commodity_polysilicon rdfs:comment "China >80% supply. Labour concerns. Input to solar PV." .
snowkap:commodity_lithium rdfs:comment "Supply concentration: Australia, Chile, China. ESG concerns: water use, community." .

