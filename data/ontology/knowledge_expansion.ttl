    snowkap:contributesToSDG snowkap:sdg_7 .
snowkap:sdg_target_8_8 rdfs:label "SDG 8.8 — Protect labour rights, safe working environments" ;
    snowkap:contributesToSDG snowkap:sdg_8 .
