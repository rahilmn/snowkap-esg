# =============================================================================
# ADDITIONAL EVENT TYPES (broaden classifier coverage)
# =============================================================================

snowkap:event_board_change a snowkap:EventType ; rdfs:label "Board / Senior Leadership Change" ;
    snowkap:scoreFloor 3 ; snowkap:scoreCeiling 7 ;
    snowkap:eventKeyword "new ceo, resignation, board reshuffle, chairperson, md appointment, independent director, whole-time director, chief financial officer, key managerial personnel, succession" ;
    snowkap:financialTransmission "governance signal -> share price volatility" .

snowkap:event_ma_deal a snowkap:EventType ; rdfs:label "Merger / Acquisition" ;
    snowkap:scoreFloor 4 ; snowkap:scoreCeiling 8 ;
    snowkap:eventKeyword "merger, acquisition, takeover, divestiture, spin-off, stake sale" ;
    snowkap:financialTransmission "portfolio shift -> valuation re-rating" .

snowkap:event_credit_rating a snowkap:EventType ; rdfs:label "Credit Rating Change" ;
    snowkap:scoreFloor 5 ; snowkap:scoreCeiling 8 ;
    snowkap:eventKeyword "moody, s&p, fitch, crisil, icra, downgrade, upgrade, outlook" ;
    snowkap:financialTransmission "rating -> cost of capital, bond spreads" .

snowkap:event_dividend_policy a snowkap:EventType ; rdfs:label "Dividend / Capital Return" ;
    snowkap:scoreFloor 2 ; snowkap:scoreCeiling 5 ;
    snowkap:eventKeyword "dividend, buyback, capital return, interim dividend" ;
    snowkap:financialTransmission "capital allocation signal -> investor sentiment" .

snowkap:event_analyst_outlook a snowkap:EventType ; rdfs:label "Analyst Outlook / Market Sentiment" ;
    snowkap:scoreFloor 2 ; snowkap:scoreCeiling 5 ;
    snowkap:eventKeyword "analyst, target price, price target, rally, upside, bullish, bearish, outperform, underperform, buy rating, sell rating, hold rating, upgrade, downgrade, broker, brokerage, coverage, overweight, underweight, sector outlook, market outlook, stock pick, top pick" ;
    snowkap:financialTransmission "analyst sentiment → investor positioning → short-term share price movement; limited ESG transmission unless tied to ESG rating action" .

snowkap:event_quarterly_results a snowkap:EventType ; rdfs:label "Quarterly / Annual Financial Results" ;
    snowkap:scoreFloor 3 ; snowkap:scoreCeiling 6 ;
    snowkap:eventKeyword "quarterly results, annual results, earnings, Q1, Q2, Q3, Q4, FY25, FY26, profit, revenue growth, EBITDA, PAT, net profit, operating profit, margin, results beat, results miss, guidance" ;
    snowkap:financialTransmission "actual financial performance → earnings revision → valuation re-rating → investor flow" .

snowkap:event_supply_chain_disruption a snowkap:EventType ; rdfs:label "Supply Chain Disruption" ;
    snowkap:scoreFloor 5 ; snowkap:scoreCeiling 8 ;
    snowkap:eventKeyword "supply chain disruption, supply shortage, shortage, stockout, inventory, lead time, logistics disruption, port congestion, freight spike, raw material shortage, input cost, commodity shortage, coal shortage, semiconductor shortage" ;
    snowkap:financialTransmission "input unavailability → production curtailment → revenue loss + expedited sourcing cost" .

snowkap:event_regulatory_policy a snowkap:EventType ; rdfs:label "Regulatory Policy Change" ;
    snowkap:scoreFloor 4 ; snowkap:scoreCeiling 7 ;
    snowkap:eventKeyword "sebi circular, rbi policy, government policy, regulatory change, new regulation, policy announcement, tariff revision, subsidy, tax policy, carbon tax, emission standard, disclosure requirement, compliance deadline" ;
    snowkap:financialTransmission "new obligation → compliance cost + strategic adjustment → sector-wide impact" .

snowkap:event_labour_strike a snowkap:EventType ; rdfs:label "Labour Strike / Dispute" ;
    snowkap:scoreFloor 5 ; snowkap:scoreCeiling 8 ;
    snowkap:eventKeyword "strike, labour dispute, union, protest, lockout, go-slow" ;
    snowkap:financialTransmission "operational disruption -> production loss, brand damage" .

snowkap:event_cyber_incident a snowkap:EventType ; rdfs:label "Cyber Incident / Data Breach" ;
    snowkap:scoreFloor 6 ; snowkap:scoreCeiling 9 ;
    snowkap:eventKeyword "cyber attack, data breach, ransomware, hack, phishing, outage" ;
    snowkap:financialTransmission "customer loss + regulatory fines + remediation cost" .

snowkap:event_community_protest a snowkap:EventType ; rdfs:label "Community Protest / Opposition" ;
    snowkap:scoreFloor 4 ; snowkap:scoreCeiling 7 ;
    snowkap:eventKeyword "protest, opposition, blockade, public hearing, land acquisition dispute, community resistance, social impact, displacement, rehabilitation, indigenous" ;
    snowkap:financialTransmission "social licence risk -> project delay / cancellation" .

snowkap:event_social_violation a snowkap:EventType ; rdfs:label "Social / Labor Rights Violation" ;
    snowkap:scoreFloor 7 ; snowkap:scoreCeiling 9 ;
    snowkap:eventKeyword "child labor, child labour, forced labor, forced labour, modern slavery, labor violation, labour violation, human rights abuse, worker exploitation, sweatshop, bonded labor, bonded labour, trafficking, labor audit, labour audit, supply chain audit failure, working conditions, underage worker, minimum wage violation, wage theft, labor rights, labour rights, occupational exploitation, contractor abuse, migrant worker abuse" ;
    snowkap:financialTransmission "Supply chain audit → remediation capex + supplier substitution + regulatory fine + brand damage + ESG fund exclusion → revenue loss + cost of capital increase" .

snowkap:event_esg_partnership a snowkap:EventType ; rdfs:label "ESG Partnership / Certification" ;
    snowkap:scoreFloor 2 ; snowkap:scoreCeiling 5 ;
    snowkap:eventKeyword "mou, partnership, joint venture, certification, sbti validated, cdp a-list" ;
    snowkap:financialTransmission "reputational uplift, potential green finance access" .

# --- NEW: Macro / sentiment / index event types (Phase 13) ---

snowkap:event_ngo_report a snowkap:EventType ; rdfs:label "NGO Report / Civil Society Ranking" ;
    snowkap:scoreFloor 4 ; snowkap:scoreCeiling 7 ;
    snowkap:eventKeyword "oxfam, greenpeace, urgewald, transparency international, amnesty, human rights watch, ngo report, billionaires list, carbon-emitting, dirty list, polluter list, climate activist, environmental group, civil society, watchdog, report card, accountability, naming and shaming, sierra club, wwf" ;
    snowkap:financialTransmission "narrative shift -> ESG fund outflow -> cost of capital uplift -> peer pressure" .

snowkap:event_climate_disclosure_index a snowkap:EventType ; rdfs:label "ESG Index / Disclosure Benchmark" ;
    snowkap:scoreFloor 5 ; snowkap:scoreCeiling 8 ;
    snowkap:eventKeyword "cdp a-list, dow jones sustainability, msci esg, sustainalytics, refinitiv, isos esg, s&p csa, ftse4good" ;
    snowkap:financialTransmission "passive index rebalancing -> ~5% share price impact -> investor flow shift" .

snowkap:event_transition_announcement a snowkap:EventType ; rdfs:label "Transition Strategy / Net Zero Announcement" ;
    snowkap:scoreFloor 4 ; snowkap:scoreCeiling 7 ;
    snowkap:eventKeyword "net zero, decarbonization, transition plan, science based target, sbti, scope 3, climate transition, renewable energy, green hydrogen, solar capacity, wind capacity, clean energy, energy transition, carbon neutral, renewable power, green power, rtc power, round the clock renewable" ;
    snowkap:financialTransmission "credibility signal -> capital allocation shift -> green premium / discount" .

snowkap:event_green_finance_milestone a snowkap:EventType ; rdfs:label "Green Finance Milestone" ;
    snowkap:scoreFloor 4 ; snowkap:scoreCeiling 7 ;
    snowkap:eventKeyword "green loan, sustainability-linked loan, transition bond, blue bond, social bond, green capex, sustainable financing facility" ;
    snowkap:financialTransmission "lower coupon -> reduced cost of debt -> investor signal" .

# Map the new event types to their TEMPLES + ESG risk overlaps
snowkap:event_ngo_report snowkap:hasImpactOn snowkap:impact_brand, snowkap:impact_reputational .
snowkap:event_climate_disclosure_index snowkap:hasImpactOn snowkap:impact_brand, snowkap:impact_financial, snowkap:impact_reputational .
snowkap:event_transition_announcement snowkap:hasImpactOn snowkap:impact_strategic, snowkap:impact_growth, snowkap:impact_financial .
snowkap:event_green_finance_milestone snowkap:hasImpactOn snowkap:impact_financial, snowkap:impact_cost, snowkap:impact_brand .

# =============================================================================
# FRAMEWORK CROSS-REFERENCES + COMPLEMENTARY CHAINS
# =============================================================================

snowkap:TCFD snowkap:hasSection snowkap:esrs_e1 .  # E1 climate aligns with TCFD
snowkap:ISSB snowkap:hasSection snowkap:tcfd_governance, snowkap:tcfd_strategy,
    snowkap:tcfd_risk_mgmt, snowkap:tcfd_metrics .  # ISSB S2 absorbs TCFD
snowkap:CSRD snowkap:hasSection snowkap:esrs_e1, snowkap:esrs_e2, snowkap:esrs_e3,
    snowkap:esrs_e4, snowkap:esrs_e5, snowkap:esrs_s1, snowkap:esrs_s2,
    snowkap:esrs_s3, snowkap:esrs_s4, snowkap:esrs_g1 .
snowkap:DJSI snowkap:hasSection snowkap:spg_csa .  # DJSI inclusion driven by S&P CSA score

