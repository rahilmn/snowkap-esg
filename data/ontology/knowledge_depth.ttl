@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix snowkap: <http://snowkap.com/ontology/esg#> .

# =============================================================================
# SNOWKAP ESG — Phase 7 Depth Layer
#
# Adds the remaining materiality × industry weights, cross-risk weights,
# stakeholder-topic depth, and cross-framework applicability. Designed
# to push the graph toward ~3000+ triples and provide comprehensive
# ontology coverage for the 7 target companies.
# =============================================================================

# =============================================================================
# COMPLETE MATERIALITY GRID — remaining (topic, industry) pairs
# =============================================================================

# --- Banking ---
snowkap:mat_waste_banking snowkap:materialityWeight 0.2 ;
