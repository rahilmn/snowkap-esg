@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix snowkap: <http://snowkap.com/ontology/esg#> .

# =============================================================================
# SNOWKAP ESG Intelligence Engine — Knowledge Base
#
# This file encodes domain knowledge as RDF triples. It REPLACES the hardcoded
# Python dicts in the legacy codebase:
#   - _TOPIC_FRAMEWORK_MAP     (ontology_service.py)
#   - MATERIALITY_MAP          (materiality_map.py)
#   - INDUSTRY_RISK_WEIGHTS    (risk_taxonomy.py)
#   - CLIMATE_RISK_ZONES       (geographic_intelligence.py)
#   - ROLE_PROFILES            (role_curation.py)
#   - HOP_DECAY                (causal_engine.py)
#   - CAP_PARAMETERS           (cap_parameters.py)
#   - Event classification rules (event_classifier.py)
# =============================================================================

# =============================================================================
# LAYER 2: ESG TOPICS (21 themes with sub-metrics)
# =============================================================================

# --- Environmental (8 topics) ---
snowkap:topic_climate a snowkap:EnvironmentalTopic ;
    rdfs:label "Climate Change" ;
    snowkap:slug "climate" ;
    snowkap:esgPillar "E" ;
    snowkap:subMetric "scope_1_direct", "scope_2_indirect", "scope_3_value_chain", "ghg_reduction_targets", "carbon_offset_credits" .

snowkap:topic_emissions a snowkap:EnvironmentalTopic ;
    rdfs:label "Emissions" ;
    snowkap:slug "emissions" ;
    snowkap:esgPillar "E" ;
    snowkap:subMetric "nox_sox_emissions", "particulate_matter", "methane_emissions", "voc_emissions" .

snowkap:topic_energy a snowkap:EnvironmentalTopic ;
    rdfs:label "Energy" ;
    snowkap:slug "energy" ;
    snowkap:esgPillar "E" ;
    snowkap:subMetric "renewable_energy_use", "energy_intensity", "fossil_fuel_dependency", "power_purchase_agreements" .

snowkap:topic_water a snowkap:EnvironmentalTopic ;
    rdfs:label "Water" ;
    snowkap:slug "water" ;
    snowkap:esgPillar "E" ;
    snowkap:subMetric "water_withdrawal", "water_consumption", "wastewater_discharge", "water_stress_regions", "water_recycling_rate" .

snowkap:topic_waste a snowkap:EnvironmentalTopic ;
    rdfs:label "Waste & Circularity" ;
    snowkap:slug "waste" ;
    snowkap:esgPillar "E" ;
    snowkap:subMetric "recycling_rate", "hazardous_waste", "circular_economy_initiatives", "landfill_diversion" .

snowkap:topic_biodiversity a snowkap:EnvironmentalTopic ;
    rdfs:label "Biodiversity" ;
    snowkap:slug "biodiversity" ;
    snowkap:esgPillar "E" ;
    snowkap:subMetric "habitat_protection", "deforestation", "species_impact", "land_restoration" .

snowkap:topic_climate_adaptation a snowkap:EnvironmentalTopic ;
    rdfs:label "Climate Adaptation" ;
    snowkap:slug "climate_adaptation" ;
    snowkap:esgPillar "E" ;
    snowkap:subMetric "physical_risk_exposure", "transition_risk", "adaptation_investment" .

snowkap:topic_pollution a snowkap:EnvironmentalTopic ;
    rdfs:label "Pollution" ;
    snowkap:slug "pollution" ;
    snowkap:esgPillar "E" ;
    snowkap:subMetric "air_quality", "water_pollution", "soil_contamination", "chemical_release" .

# --- Social (7 topics) ---
snowkap:topic_human_capital a snowkap:SocialTopic ;
    rdfs:label "Human Capital" ;
    snowkap:slug "human_capital" ;
    snowkap:esgPillar "S" ;
    snowkap:subMetric "employee_turnover", "fair_wages", "talent_retention", "training_hours" .

snowkap:topic_health_safety a snowkap:SocialTopic ;
    rdfs:label "Health & Safety" ;
    snowkap:slug "health_safety" ;
    snowkap:esgPillar "S" ;
    snowkap:subMetric "workplace_injuries", "fatality_rate", "ltifr", "near_miss_reporting" .

snowkap:topic_community a snowkap:SocialTopic ;
    rdfs:label "Community Impact" ;
    snowkap:slug "community" ;
    snowkap:esgPillar "S" ;
    snowkap:subMetric "local_employment", "indigenous_rights", "social_license", "csr_spend" .

snowkap:topic_supply_chain_labor a snowkap:SocialTopic ;
    rdfs:label "Supply Chain Labor" ;
    snowkap:slug "supply_chain_labor" ;
    snowkap:esgPillar "S" ;
    snowkap:subMetric "child_labor_risk", "forced_labor_risk", "living_wage_compliance", "supplier_audits" .

snowkap:topic_dei a snowkap:SocialTopic ;
    rdfs:label "Diversity, Equity & Inclusion" ;
    snowkap:slug "dei" ;
    snowkap:esgPillar "S" ;
    snowkap:subMetric "gender_pay_gap", "board_diversity", "inclusion_programs", "women_in_leadership" .

snowkap:topic_product_safety a snowkap:SocialTopic ;
    rdfs:label "Product Safety" ;
    snowkap:slug "product_safety" ;
    snowkap:esgPillar "S" ;
    snowkap:subMetric "product_recalls", "customer_complaints", "safety_certifications", "quality_audits" .

snowkap:topic_data_privacy a snowkap:SocialTopic ;
    rdfs:label "Data Privacy & Security" ;
    snowkap:slug "data_privacy" ;
    snowkap:esgPillar "S" ;
    snowkap:subMetric "data_breaches", "cybersecurity_investment", "privacy_certifications", "dpdp_compliance" .

# --- Governance (6 topics) ---
snowkap:topic_board_leadership a snowkap:GovernanceTopic ;
