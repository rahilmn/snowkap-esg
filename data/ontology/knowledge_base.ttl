    snowkap:deadlineDate "2026-07-31"^^xsd:date ;
    snowkap:recurrence "annual" ;
    snowkap:applicabilityCondition "Companies requested by investors or customers" ;
    snowkap:penaltyForNonCompliance "No direct penalty, but F score impacts investor perception" .

