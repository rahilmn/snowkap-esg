# =============================================================================
# MATERIALITY WEIGHTS (Topic × Industry) — replaces MATERIALITY_MAP dict
# Weights: 1.0 = critical, 0.7-0.9 = high, 0.4-0.6 = medium, <0.4 = low
# Encoded via blank nodes since rdflib handles them efficiently
# =============================================================================

snowkap:topic_climate snowkap:materialFor snowkap:industry_banking ;
    snowkap:materialFor snowkap:industry_asset_mgmt ;
    snowkap:materialFor snowkap:industry_power ;
    snowkap:materialFor snowkap:industry_renewable ;
    snowkap:materialFor snowkap:industry_oil_gas ;
    snowkap:materialFor snowkap:industry_mining ;
    snowkap:materialFor snowkap:industry_steel ;
    snowkap:materialFor snowkap:industry_chemicals .

# Use reified triples for materiality with weight via statements
snowkap:mat_climate_banking snowkap:materialityWeight 0.8 ;
    rdf:subject snowkap:topic_climate ; rdf:predicate snowkap:materialFor ; rdf:object snowkap:industry_banking .
