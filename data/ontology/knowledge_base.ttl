# =============================================================================
# LAYER 3: IMPACT DIMENSIONS
# =============================================================================

snowkap:impact_financial a snowkap:ImpactDimension ;
    rdfs:label "Financial Impact" ;
    snowkap:slug "financial" .

snowkap:impact_regulatory a snowkap:ImpactDimension ;
    rdfs:label "Regulatory Impact" ;
    snowkap:slug "regulatory" .

snowkap:impact_operational a snowkap:ImpactDimension ;
    rdfs:label "Operational Impact" ;
    snowkap:slug "operational" .

snowkap:impact_reputational a snowkap:ImpactDimension ;
    rdfs:label "Reputational Impact" ;
    snowkap:slug "reputational" .

snowkap:impact_strategic a snowkap:ImpactDimension ;
    rdfs:label "Strategic Impact" ;
    snowkap:slug "strategic" .

# TEMPLES impact dimensions (from Excel risk register data)
snowkap:impact_volume a snowkap:ImpactDimension ;
    rdfs:label "Volume Impact" ;
    snowkap:slug "volume" .

snowkap:impact_value a snowkap:ImpactDimension ;
    rdfs:label "Value Impact" ;
    snowkap:slug "value" .

snowkap:impact_cost a snowkap:ImpactDimension ;
    rdfs:label "Cost Impact" ;
    snowkap:slug "cost" .

snowkap:impact_growth a snowkap:ImpactDimension ;
    rdfs:label "Growth Impact" ;
    snowkap:slug "growth" .

snowkap:impact_brand a snowkap:ImpactDimension ;
    rdfs:label "Brand Impact" ;
    snowkap:slug "brand" .

# --- Topic → Impact (what dimensions does each topic affect?) ---
snowkap:topic_climate snowkap:hasImpactOn snowkap:impact_financial, snowkap:impact_regulatory, snowkap:impact_operational, snowkap:impact_cost, snowkap:impact_strategic .
snowkap:topic_emissions snowkap:hasImpactOn snowkap:impact_regulatory, snowkap:impact_cost, snowkap:impact_reputational .
snowkap:topic_energy snowkap:hasImpactOn snowkap:impact_cost, snowkap:impact_operational, snowkap:impact_financial .
snowkap:topic_water snowkap:hasImpactOn snowkap:impact_operational, snowkap:impact_cost, snowkap:impact_volume, snowkap:impact_financial, snowkap:impact_strategic, snowkap:impact_reputational .
snowkap:topic_waste snowkap:hasImpactOn snowkap:impact_regulatory, snowkap:impact_cost, snowkap:impact_reputational .
snowkap:topic_biodiversity snowkap:hasImpactOn snowkap:impact_regulatory, snowkap:impact_reputational, snowkap:impact_operational .
snowkap:topic_climate_adaptation snowkap:hasImpactOn snowkap:impact_operational, snowkap:impact_financial, snowkap:impact_strategic, snowkap:impact_volume .
snowkap:topic_pollution snowkap:hasImpactOn snowkap:impact_regulatory, snowkap:impact_reputational, snowkap:impact_brand .
snowkap:topic_human_capital snowkap:hasImpactOn snowkap:impact_operational, snowkap:impact_cost, snowkap:impact_brand, snowkap:impact_growth .
snowkap:topic_health_safety snowkap:hasImpactOn snowkap:impact_operational, snowkap:impact_regulatory, snowkap:impact_reputational, snowkap:impact_cost .
snowkap:topic_community snowkap:hasImpactOn snowkap:impact_reputational, snowkap:impact_brand, snowkap:impact_operational .
snowkap:topic_supply_chain_labor snowkap:hasImpactOn snowkap:impact_reputational, snowkap:impact_brand, snowkap:impact_regulatory, snowkap:impact_operational .
snowkap:topic_dei snowkap:hasImpactOn snowkap:impact_reputational, snowkap:impact_brand, snowkap:impact_growth .
snowkap:topic_product_safety snowkap:hasImpactOn snowkap:impact_reputational, snowkap:impact_brand, snowkap:impact_regulatory, snowkap:impact_value .
snowkap:topic_data_privacy snowkap:hasImpactOn snowkap:impact_regulatory, snowkap:impact_reputational, snowkap:impact_financial, snowkap:impact_brand .
snowkap:topic_board_leadership snowkap:hasImpactOn snowkap:impact_strategic, snowkap:impact_reputational, snowkap:impact_financial .
snowkap:topic_ethics_compliance snowkap:hasImpactOn snowkap:impact_regulatory, snowkap:impact_reputational, snowkap:impact_financial, snowkap:impact_brand .
snowkap:topic_risk_management snowkap:hasImpactOn snowkap:impact_strategic, snowkap:impact_financial, snowkap:impact_operational .
snowkap:topic_transparency snowkap:hasImpactOn snowkap:impact_regulatory, snowkap:impact_financial, snowkap:impact_reputational .
snowkap:topic_tax_transparency snowkap:hasImpactOn snowkap:impact_regulatory, snowkap:impact_financial, snowkap:impact_reputational .
snowkap:topic_stakeholder_governance snowkap:hasImpactOn snowkap:impact_strategic, snowkap:impact_reputational, snowkap:impact_financial .

# =============================================================================
# LAYER 4: PERSPECTIVE LENSES
# =============================================================================

snowkap:lens_esg_analyst a snowkap:PerspectiveLens ;
    rdfs:label "ESG Analyst" ;
    snowkap:slug "esg-analyst" ;
    snowkap:outputDepth "detailed" ;
    snowkap:financialFraming "esg_scoring" .

snowkap:lens_cfo a snowkap:PerspectiveLens ;
    rdfs:label "CFO" ;
    snowkap:slug "cfo" ;
    snowkap:outputDepth "brief" ;
    snowkap:financialFraming "pnl" ;
    snowkap:maxWords 100 .

snowkap:lens_ceo a snowkap:PerspectiveLens ;
    rdfs:label "CEO" ;
    snowkap:slug "ceo" ;
    snowkap:outputDepth "brief" ;
    snowkap:financialFraming "strategic" ;
    snowkap:maxWords 150 .

# --- Impact → Perspective relevance (the core of perspective transformation) ---
snowkap:impact_financial snowkap:relevantTo snowkap:lens_cfo, snowkap:lens_esg_analyst .
snowkap:impact_regulatory snowkap:relevantTo snowkap:lens_cfo, snowkap:lens_esg_analyst, snowkap:lens_ceo .
snowkap:impact_operational snowkap:relevantTo snowkap:lens_esg_analyst, snowkap:lens_cfo .
snowkap:impact_reputational snowkap:relevantTo snowkap:lens_ceo, snowkap:lens_esg_analyst .
snowkap:impact_strategic snowkap:relevantTo snowkap:lens_ceo, snowkap:lens_esg_analyst .
snowkap:impact_volume snowkap:relevantTo snowkap:lens_cfo, snowkap:lens_esg_analyst .
snowkap:impact_value snowkap:relevantTo snowkap:lens_cfo, snowkap:lens_esg_analyst .
snowkap:impact_cost snowkap:relevantTo snowkap:lens_cfo, snowkap:lens_esg_analyst .
snowkap:impact_growth snowkap:relevantTo snowkap:lens_ceo, snowkap:lens_esg_analyst .
snowkap:impact_brand snowkap:relevantTo snowkap:lens_ceo, snowkap:lens_esg_analyst .

# =============================================================================
# LAYER 5: ESG FRAMEWORKS (21 total)
# =============================================================================

# --- Core ESG frameworks (13) ---
snowkap:BRSR a snowkap:ESGFramework ; rdfs:label "BRSR" ;
    rdfs:comment "Business Responsibility and Sustainability Reporting (India, SEBI)" ;
    snowkap:profitabilityLink "Non-disclosure → SEBI scrutiny → trading restrictions → cost of capital +20-40bps" .

snowkap:GRI a snowkap:ESGFramework ; rdfs:label "GRI" ;
    rdfs:comment "Global Reporting Initiative" ;
    snowkap:profitabilityLink "Weak GRI disclosure → lower ESG ratings → fund outflow" .

snowkap:TCFD a snowkap:ESGFramework ; rdfs:label "TCFD" ;
    rdfs:comment "Task Force on Climate-Related Financial Disclosures" ;
    snowkap:profitabilityLink "Non-disclosure → FII outflow → P/E compression 5-10%" .

snowkap:CSRD a snowkap:ESGFramework ; rdfs:label "CSRD" ;
    rdfs:comment "Corporate Sustainability Reporting Directive (EU)" ;
    snowkap:profitabilityLink "Non-compliance → 2% global turnover fine, EU market access loss" .

snowkap:ESRS a snowkap:ESGFramework ; rdfs:label "ESRS" ;
    rdfs:comment "European Sustainability Reporting Standards" ;
    snowkap:profitabilityLink "Part of CSRD compliance — mandatory for EU operations" .

snowkap:SASB a snowkap:ESGFramework ; rdfs:label "SASB" ;
    rdfs:comment "Sustainability Accounting Standards Board (industry-specific)" ;
    snowkap:profitabilityLink "Used by investors for peer benchmarking" .

snowkap:ISSB a snowkap:ESGFramework ; rdfs:label "ISSB / IFRS S1 S2" ;
    rdfs:comment "International Sustainability Standards Board" ;
    snowkap:profitabilityLink "Global baseline — affects cross-border investor confidence" .

snowkap:EU_TAXONOMY a snowkap:ESGFramework ; rdfs:label "EU Taxonomy" ;
    rdfs:comment "EU classification of environmentally sustainable activities" ;
    snowkap:profitabilityLink "Aligned activities unlock green financing, lower cost of capital" .

snowkap:SFDR a snowkap:ESGFramework ; rdfs:label "SFDR" ;
    rdfs:comment "EU Sustainable Finance Disclosure Regulation" ;
    snowkap:profitabilityLink "Required for EU fund marketing — affects capital access" .

snowkap:CDP a snowkap:ESGFramework ; rdfs:label "CDP" ;
    rdfs:comment "CDP (Carbon Disclosure Project)" ;
    snowkap:profitabilityLink "CDP score tracked by investors; A-list inclusion = premium valuation" .

snowkap:SBTI a snowkap:ESGFramework ; rdfs:label "SBTi" ;
    rdfs:comment "Science Based Targets initiative" ;
    snowkap:profitabilityLink "Credibility for net-zero claims → investor confidence" .

snowkap:TNFD a snowkap:ESGFramework ; rdfs:label "TNFD" ;
    rdfs:comment "Taskforce on Nature-related Financial Disclosures" ;
    snowkap:profitabilityLink "Emerging standard — nature-related risks affect insurance, financing" .

snowkap:SEC_CLIMATE a snowkap:ESGFramework ; rdfs:label "SEC Climate Rule" ;
    rdfs:comment "US SEC Climate Disclosure Rules" ;
    snowkap:profitabilityLink "US-listed companies face enforcement + litigation risk" .

# --- Strategy frameworks (3) ---
snowkap:PORTER_5_FORCES a snowkap:ESGFramework ; rdfs:label "Porter Five Forces" ;
    rdfs:comment "Michael Porter competitive strategy framework" ;
    snowkap:profitabilityLink "Structural industry analysis for ESG-driven competitive shifts" .

snowkap:MCKINSEY_3_HORIZONS a snowkap:ESGFramework ; rdfs:label "McKinsey Three Horizons" ;
    rdfs:comment "Innovation portfolio classification (H1 core, H2 emerging, H3 transformative)" ;
    snowkap:profitabilityLink "ESG opportunities mapped across H1/H2/H3 investment horizons" .

snowkap:BCG_MATRIX a snowkap:ESGFramework ; rdfs:label "BCG Matrix" ;
    rdfs:comment "Growth-share matrix for portfolio classification" ;
    snowkap:profitabilityLink "Classify ESG initiatives as stars, cash cows, question marks, dogs" .

# --- Risk / Governance frameworks (1) ---
snowkap:COSO_ERM a snowkap:ESGFramework ; rdfs:label "COSO ERM" ;
    rdfs:comment "Committee of Sponsoring Organizations Enterprise Risk Management" ;
    snowkap:profitabilityLink "ERM maturity affects credit rating, cost of capital, board oversight" .

# --- Finance frameworks (1) ---
snowkap:CFA_ESG a snowkap:ESGFramework ; rdfs:label "CFA ESG Integration" ;
    rdfs:comment "CFA Institute ESG factor integration in valuation" ;
    snowkap:profitabilityLink "ESG factors integrated into DCF, multiples, cost of capital models" .

# --- ESG Indices (2) ---
snowkap:DJSI a snowkap:ESGFramework ; rdfs:label "Dow Jones Sustainability Index" ;
    rdfs:comment "S&P Dow Jones Sustainability Index" ;
    snowkap:profitabilityLink "DJSI inclusion → ESG fund inflows, ~5-10% valuation premium" .

snowkap:SP_GLOBAL_ESG a snowkap:ESGFramework ; rdfs:label "S&P Global ESG" ;
    rdfs:comment "S&P Global Corporate Sustainability Assessment (CSA)" ;
    snowkap:profitabilityLink "Score drives DJSI inclusion + passive ESG fund tracking" .

# --- Reputation frameworks (1) ---
snowkap:EDELMAN a snowkap:ESGFramework ; rdfs:label "Edelman Trust Barometer" ;
    rdfs:comment "Annual trust measurement across stakeholders" ;
    snowkap:profitabilityLink "Trust score correlates with customer retention, talent acquisition" .

