    snowkap:esgPillar "G" ;
    snowkap:subMetric "cybersecurity_governance", "business_continuity", "erm_maturity", "risk_committees" .

snowkap:topic_transparency a snowkap:GovernanceTopic ;
    rdfs:label "Transparency & Disclosure" ;
    snowkap:slug "transparency" ;
    snowkap:esgPillar "G" ;
    snowkap:subMetric "esg_reporting", "audit_quality", "disclosure_completeness" .

snowkap:topic_tax_transparency a snowkap:GovernanceTopic ;
    rdfs:label "Tax Transparency" ;
