# =============================================================================
# EVENT TYPES (replaces event_classifier.py hardcoded rules)
# =============================================================================

snowkap:event_criminal_indictment a snowkap:EventType ; rdfs:label "Criminal Indictment" ;
    snowkap:scoreFloor 8 ; snowkap:scoreCeiling 10 ;
    snowkap:eventKeyword "criminal, indicted, cbi, ed raid, prosecution, arrested, fraud, scam, money laundering, enforcement directorate, chargesheet" ;
    snowkap:financialTransmission "brand destruction → share price → cost of capital spike" .

snowkap:event_license_revocation a snowkap:EventType ; rdfs:label "License Revocation" ;
    snowkap:scoreFloor 8 ; snowkap:scoreCeiling 10 ;
    snowkap:eventKeyword "license revoked, banned, blacklisted, debarred, suspended operations, cease and desist, operating permit" ;
    snowkap:financialTransmission "operations halt → revenue loss → going concern doubt" .

snowkap:event_systemic_regulatory a snowkap:EventType ; rdfs:label "Systemic Regulatory Change" ;
    snowkap:scoreFloor 7 ; snowkap:scoreCeiling 9 ;
    snowkap:eventKeyword "all listed, sector-wide, brsr mandatory, sebi circular, new regulation, regulatory overhaul, policy change, rbi directive, ministry notification" ;
    snowkap:financialTransmission "compliance cost ↑ → margin compression → sector re-rating" .

snowkap:event_heavy_penalty a snowkap:EventType ; rdfs:label "Heavy Regulatory Penalty" ;
    snowkap:scoreFloor 7 ; snowkap:scoreCeiling 9 ;
    snowkap:eventKeyword "heavy penalty, record fine, penalty of rs, gst demand, tax demand, show cause notice, adjudication order, tribunal, penalty order, enforcement action" ;
    snowkap:financialTransmission "direct P&L hit + precedent risk" .

snowkap:event_esg_rating_change a snowkap:EventType ; rdfs:label "ESG Rating Change" ;
    snowkap:scoreFloor 5 ; snowkap:scoreCeiling 7 ;
    snowkap:eventKeyword "esg rating, msci esg, sustainalytics, removed from index, esg score, nse sustainability, crisil esg, esg assessment, rating upgrade, rating downgrade, esg revised" ;
    snowkap:financialTransmission "passive fund rebalancing → ~5% share price impact" .

snowkap:event_green_bond a snowkap:EventType ; rdfs:label "Green Bond Issuance" ;
    snowkap:scoreFloor 4 ; snowkap:scoreCeiling 7 ;
    snowkap:eventKeyword "green bond, esg bond, sustainability-linked, climate bond, social bond, blue bond, sustainable finance" ;
    snowkap:financialTransmission "green premium → reduced coupon → lower cost of debt" .

snowkap:event_climate_event a snowkap:EventType ; rdfs:label "Climate Physical Event" ;
    snowkap:scoreFloor 5 ; snowkap:scoreCeiling 9 ;
    snowkap:eventKeyword "flood, cyclone, heatwave, drought, wildfire, extreme weather, el nino, la nina, sea level, glacier, monsoon, tornado, hurricane, climate disaster" ;
    snowkap:financialTransmission "facility disruption → production loss → insurance claim" .

snowkap:event_routine_capex a snowkap:EventType ; rdfs:label "Routine Capex" ;
    snowkap:scoreFloor 1 ; snowkap:scoreCeiling 5 ;
    snowkap:eventKeyword "capex, expansion plan, new facility, greenfield, brownfield, commissioning, capacity addition, plant inauguration, project completion, green ammonia, green hydrogen, green capex, renewable energy procurement, low-carbon procurement, clean fuel deal, decarbonisation deal, decarbonization deal, energy transition deal, sustainable procurement" ;
    snowkap:financialTransmission "balance sheet growth — no immediate ESG signal" .

snowkap:event_award_recognition a snowkap:EventType ; rdfs:label "Award / Recognition" ;
    snowkap:scoreFloor 1 ; snowkap:scoreCeiling 3 ;
    snowkap:eventKeyword "award, best company, ranked, recognition, accolade, certified, top employer, great place to work, excellence award, sustainability award" ;
    snowkap:financialTransmission "minor PR benefit — no material impact" .

