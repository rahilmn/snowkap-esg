# =============================================================================
# RISK CATEGORIES (10 ESG categories)
# =============================================================================

snowkap:risk_physical a snowkap:RiskCategory ; rdfs:label "Physical Risk" ;
    snowkap:hasLeadIndicator "monsoon forecast, reservoir levels, temperature anomalies, cyclone tracking" ;
    snowkap:hasLagIndicator "production downtime, insurance claims, damage assessments" .

snowkap:risk_supply_chain a snowkap:RiskCategory ; rdfs:label "Supply Chain Risk" ;
    snowkap:hasLeadIndicator "commodity price trends, supplier financial health, concentration ratios" ;
    snowkap:hasLagIndicator "supplier failures, delivery delays, cost overruns" .

snowkap:risk_reputational a snowkap:RiskCategory ; rdfs:label "Reputational Risk" ;
    snowkap:hasLeadIndicator "social media sentiment, NGO campaigns, whistleblower reports" ;
    snowkap:hasLagIndicator "brand score decline, customer churn, boycotts" .

snowkap:risk_regulatory a snowkap:RiskCategory ; rdfs:label "Regulatory Risk" ;
    snowkap:hasLeadIndicator "draft regulations, public consultations, regulator speeches" ;
    snowkap:hasLagIndicator "enforcement actions, fines, license conditions" .

snowkap:risk_litigation a snowkap:RiskCategory ; rdfs:label "Litigation Risk" ;
    snowkap:hasLeadIndicator "class action pre-filings, activist investor campaigns, regulatory investigations" ;
    snowkap:hasLagIndicator "lawsuits filed, settlements, penalties" .

snowkap:risk_transition a snowkap:RiskCategory ; rdfs:label "Transition Risk" ;
    snowkap:hasLeadIndicator "tech adoption curves, policy roadmaps, customer preference shifts" ;
    snowkap:hasLagIndicator "stranded assets, demand destruction, market share loss" .

snowkap:risk_human_capital a snowkap:RiskCategory ; rdfs:label "Human Capital Risk" ;
    snowkap:hasLeadIndicator "employee engagement surveys, turnover trends, union activity" ;
    snowkap:hasLagIndicator "mass attrition, strikes, talent gaps" .

snowkap:risk_technological a snowkap:RiskCategory ; rdfs:label "Technological Risk" ;
    snowkap:hasLeadIndicator "penetration testing results, vulnerability disclosures, tech debt" ;
    snowkap:hasLagIndicator "data breaches, system outages, customer data loss" .

snowkap:risk_manpower a snowkap:RiskCategory ; rdfs:label "Manpower Risk" ;
    snowkap:hasLeadIndicator "labor market indicators, demographic shifts, skill gap analyses" ;
    snowkap:hasLagIndicator "absenteeism, productivity drops, recruitment failures" .

snowkap:risk_market_uncertainty a snowkap:RiskCategory ; rdfs:label "Market & Uncertainty" ;
    snowkap:hasLeadIndicator "VIX, FX volatility, geopolitical tensions, ESG fund flows" ;
    snowkap:hasLagIndicator "valuation compression, capital flight, downgrades" .

